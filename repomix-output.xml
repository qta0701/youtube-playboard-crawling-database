    <!-- Channel Detail Modal -->
    <div class="modal" id="channelModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>채널 상세 정보</h3>
                <button class="modal-close" onclick="closeModal()">&times;</button>
