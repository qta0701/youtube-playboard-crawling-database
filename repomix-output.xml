    <script>
        // ============================================================
        // 디버그 로그 시스템 (Debug Logging System)
        // ============================================================
        const debugLogs = [];
        const MAX_LOGS = 500;  // 메모리 최적화: 500개로 축소
        let DEBUG_VERBOSE = false;  // true면 상세 로그, false면 핵심 로그만

        function debugLog(category, message, data = null, verbose = false) {
            // VERBOSE 모드가 아니고, verbose 로그면 스킵
            if (verbose && !DEBUG_VERBOSE) return;

            const timestamp = new Date().toISOString();
            const logEntry = {
                timestamp,
                category,
                message,
                data: data ? JSON.stringify(data, null, 2) : null
            };
            debugLogs.push(logEntry);

            // 최대 로그 수 제한
            if (debugLogs.length > MAX_LOGS) {
                debugLogs.shift();
            }

            // 콘솔에도 출력
            const logStyle = {
                'TAB': 'color: #9c27b0; font-weight: bold;',
                'API': 'color: #2196f3; font-weight: bold;',
                'API_START': 'color: #03a9f4; font-weight: bold;',
                'API_END': 'color: #00bcd4; font-weight: bold;',
                'ERROR': 'color: #f44336; font-weight: bold;',
                'SUCCESS': 'color: #4caf50; font-weight: bold;',
                'INFO': 'color: #ff9800; font-weight: bold;',
                'WARN': 'color: #ffc107; font-weight: bold;',
                'CHANNEL_MANAGER': 'color: #667eea; font-weight: bold;',
                'CHANNEL_VIEWER': 'color: #e91e63; font-weight: bold;',
                'VIEW_MODE': 'color: #795548; font-weight: bold;',
                'BUTTON': 'color: #607d8b; font-weight: bold;',
                'PLAYLIST': 'color: #009688; font-weight: bold;',
                'DETAIL': 'color: #9e9e9e;'
            };

            console.log(
                `%c[${timestamp}] [${category}]%c ${message}`,
                logStyle[category] || 'color: #333;',
                'color: #333;',
                data || ''
            );
        }

        // VERBOSE 모드 토글 함수 (개발자 콘솔에서 호출 가능)
        function toggleDebugVerbose() {
            DEBUG_VERBOSE = !DEBUG_VERBOSE;
            console.log(`[DEBUG] Verbose mode: ${DEBUG_VERBOSE ? 'ON' : 'OFF'}`);
            return DEBUG_VERBOSE;
        }

        function downloadDebugLogs() {
            const logText = debugLogs.map(log => {
                let line = `[${log.timestamp}] [${log.category}] ${log.message}`;
                if (log.data) {
                    line += `\n  Data: ${log.data}`;
                }
                return line;
            }).join('\n');

            const blob = new Blob([logText], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `debug_log_${new Date().toISOString().replace(/[:.]/g, '-')}.txt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);

            debugLog('INFO', '디버그 로그 다운로드 완료', { totalLogs: debugLogs.length });
        }

        function clearDebugLogs() {
            debugLogs.length = 0;
            debugLog('INFO', '디버그 로그 초기화됨');
            alert('디버그 로그가 초기화되었습니다.');
        }

        // ============================================================
        // State
        // ============================================================
        let currentTab = 'crawl';
        let currentApiSubtype = 'channels';
        let currentCollType = 'shorts';
        let apiPage = 1;
        let apiTotalPages = 1;
        let crawlPage = 1;
        let crawlTotalPages = 1;
        const PAGE_SIZE = 20;
        let selectedChannels = new Set();
        let collectionData = { shorts: [], videos: [], channels: [] };
        let categoriesList = [];
        let countriesList = [];

        // PLAN.md 2.1: API Data View Mode (grid or table)
        let apiViewMode = 'grid';  // 기본값: 그리드

        // PLAN.md 2.1.B: Channel Viewer State
        let cvChannelId = null;
        let cvChannelName = '';
        let cvPage = 1;
        let cvTotalPages = 1;
        let cvViewMode = 'grid';
        const CV_PAGE_SIZE = 24;

        // 수집 데이터 미리보기 상태
        let collectedDataType = null;
        let collectedDataPage = 1;
        let collectedDataTotalPages = 1;

        // Init - PLAN.md 1.1: 안전한 초기화 및 에러처리
        document.addEventListener('DOMContentLoaded', async () => {
            try {
                // 1. 탭 이벤트 리스너를 가장 먼저 설정 (데이터 로딩 실패해도 탭 전환 가능)
                setupTabs();
                console.log('[Init] 탭 이벤트 리스너 설정 완료');

                // 2. Safety Timeout: 8초 후 로딩 스피너가 남아있으면 강제 제거
                setTimeout(() => {
                    const spinners = document.querySelectorAll('.loading .spinner');
                    spinners.forEach(spinner => {
                        const parent = spinner.closest('.loading');
                        if (parent) {
                            console.warn('[Safety Timeout] 로딩 스피너 강제 제거');
                            parent.innerHTML = '<div style="color:#f44336;padding:20px;">⚠️ 데이터 로딩 지연됨 (F12 콘솔 확인)</div>';
                        }
                    });
                    showToast('데이터 로딩 시간이 길어지고 있습니다. 새로고침을 시도하세요.', 'warning', 5000);
                }, 8000);

                // 3. 데이터 로드 (병렬로 실행)
                console.log('[Init] 데이터 로드 시작...');
                await Promise.all([
                    loadStats().catch(e => console.error('[Init] loadStats 에러:', e)),
                    loadQuota().catch(e => console.error('[Init] loadQuota 에러:', e)),
                    loadCollectionStatus().catch(e => console.error('[Init] loadCollectionStatus 에러:', e)),
                    loadCrawlHistory().catch(e => console.error('[Init] loadCrawlHistory 에러:', e)),
                    loadRecentCrawlHistory().catch(e => console.error('[Init] loadRecentCrawlHistory 에러:', e)),
                    loadCrawlData().catch(e => console.error('[Init] loadCrawlData 에러:', e))
                ]);
                console.log('[Init] 데이터 로드 완료');

                // 4. UI 기능 활성화
                enableColumnResizing();  // PLAN Phase 2.3: 컬럼 리사이징 활성화
                syncTopScroll();  // [FIX] 상단 스크롤 동기화 초기화
                console.log('[Init] 초기화 완료');

            } catch (criticalError) {
                console.error('[CRITICAL] 대시보드 초기화 오류:', criticalError);
                showToast('대시보드 초기화 중 오류가 발생했습니다: ' + criticalError.message, 'error', 10000);
            }
        });

        // Setup Tabs
        function setupTabs() {
            document.querySelectorAll('.main-tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    const prevTab = currentTab;
                    document.querySelectorAll('.main-tab').forEach(t => t.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                    tab.classList.add('active');
                    currentTab = tab.dataset.tab;
                    document.getElementById(currentTab + 'Tab').classList.add('active');

                    // 탭 전환 디버그 로그
                    debugLog('TAB', `탭 전환: ${prevTab} → ${currentTab}`);

                    if (currentTab === 'api') {
                        loadApiData();
                    }
                });
            });

            // API sub tabs (PLAN.md Phase 2: 채널 탭도 테이블 뷰 지원)
            document.querySelectorAll('.sub-tab[data-subtype]').forEach(tab => {
                tab.addEventListener('click', () => {
                    document.querySelectorAll('.sub-tab[data-subtype]').forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    currentApiSubtype = tab.dataset.subtype;
                    apiPage = 1;

                    loadApiData();
                    debugLog('TAB', `서브탭 전환: ${tab.dataset.subtype}, ViewMode: ${apiViewMode}`);
                });
            });

            // Collection sub tabs
            document.querySelectorAll('.sub-tab[data-colltype]').forEach(tab => {
                tab.addEventListener('click', () => {
                    document.querySelectorAll('.sub-tab[data-colltype]').forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    currentCollType = tab.dataset.colltype;
                    renderCollectionGrid();
                });
            });

            document.getElementById('apiPrev').addEventListener('click', () => {
                if (apiPage > 1) { apiPage--; loadApiData(); }
            });
            document.getElementById('apiNext').addEventListener('click', () => {
                if (apiPage < apiTotalPages) { apiPage++; loadApiData(); }
            });

            document.getElementById('crawlPrev').addEventListener('click', () => {
                if (crawlPage > 1) { crawlPage--; loadCrawlData(); }
            });
            document.getElementById('crawlNext').addEventListener('click', () => {
                if (crawlPage < crawlTotalPages) { crawlPage++; loadCrawlData(); }
            });

            // Enter key search
            document.getElementById('crawlSearch').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') searchCrawlData();
            });
        }

        // Load Stats
        async function loadStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('crawlShorts').textContent = data.crawl_data.shorts.toLocaleString();
                    document.getElementById('crawlVideos').textContent = data.crawl_data.videos.toLocaleString();
                    document.getElementById('crawlChannels').textContent = data.crawl_data.channels.toLocaleString();
                    document.getElementById('apiChannels').textContent = data.api_data.channels.toLocaleString();
                    document.getElementById('apiShorts').textContent = data.api_data.shorts.toLocaleString();
                    document.getElementById('apiVideos').textContent = data.api_data.videos.toLocaleString();

                    const crawlTotal = data.crawl_data.shorts + data.crawl_data.videos + data.crawl_data.channels;
                    const apiTotal = data.api_data.channels + data.api_data.shorts + data.api_data.videos;
                    document.getElementById('headerCrawlTotal').textContent = crawlTotal.toLocaleString();
                    document.getElementById('headerApiTotal').textContent = apiTotal.toLocaleString();

                    // Update status tab summary
                    document.getElementById('statusTotalItems').textContent = crawlTotal.toLocaleString();
                }
            } catch (e) { console.error('Stats error:', e); }
        }

        // Load Quota
        async function loadQuota() {
            try {
                const res = await fetch('/api/quota');
                const data = await res.json();
                if (data.status === 'success') {
                    const { total_used, limit, percentage } = data.today;
                    document.getElementById('quotaValue').textContent = `${total_used.toLocaleString()} / ${limit.toLocaleString()} 유닛 (${percentage}%)`;
                    const fill = document.getElementById('quotaFill');
                    fill.style.width = `${percentage}%`;
                    fill.className = `quota-fill ${data.color}`;
                }
            } catch (e) { console.error('Quota error:', e); }
        }

        // [PLAN Phase 3.2] Load Collection Status - 여러 날짜 데이터 처리 (periodType 파라미터 추가)
        async function loadCollectionStatus(baseDate = null, periodType = null) {
            try {
                // URL 파라미터 생성
                let url = '/api/collection_status';
                const params = new URLSearchParams();

                // [PLAN Phase 3.2] periodType이 인자로 전달되지 않으면 select 요소에서 가져옴
                if (!periodType) {
                    periodType = document.getElementById('collectionPeriodType').value;
                }

                // period_type 파라미터 추가 (일간/주간 구분)
                params.append('period_type', periodType);

                // [PLAN Phase 3.2] 기준 날짜 (baseDate가 없으면 오늘)
                const today = new Date().toISOString().split('T')[0];
                params.append('base_date', baseDate || today);

                url += '?' + params.toString();

                const res = await fetch(url);
                const data = await res.json();

                if (data.status === 'success') {
                    // Store metadata
                    categoriesList = data.categories || [];
                    countriesList = data.countries || [];

                    // Populate filter dropdowns
                    populateFilters();

                    // [PLAN Phase 1.2] Render collection cards (날짜별 카드)
                    renderCollectionCards(data);
                }
            } catch (e) {
                console.error('Collection status error:', e);
                document.getElementById('collectionCardsContainer').innerHTML =
                    '<div style="color:#f44336;padding:20px;">❌ 데이터 로드 실패</div>';
            }
        }

        // [PLAN Phase 1.2] Render Collection Cards - 날짜별 카드 렌더링
        function renderCollectionCards(data) {
            const container = document.getElementById('collectionCardsContainer');
            const dates = data.data || {};
            const periodType = data.period_type || 'daily';

            if (Object.keys(dates).length === 0) {
                container.innerHTML = '<div style="color:#888;padding:20px;">수집된 데이터가 없습니다.</div>';
                return;
            }

            let cardsHTML = '';

            // 날짜별로 카드 생성
            for (const [dateKey, dateData] of Object.entries(dates)) {
                const shorts = dateData.shorts || [];
                const videos = dateData.videos || [];
                const channels = dateData.channels || [];

                const shortsCount = shorts.reduce((sum, item) => sum + (item.count || 0), 0);
                const videosCount = videos.reduce((sum, item) => sum + (item.count || 0), 0);
                const channelsCount = channels.reduce((sum, item) => sum + (item.count || 0), 0);

                // 날짜 레이블 포맷팅
                let dateLabel = dateKey;
                if (periodType === 'daily') {
                    const today = new Date().toISOString().split('T')[0];
                    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
                    const dayBefore = new Date(Date.now() - 172800000).toISOString().split('T')[0];

                    if (dateKey === today) dateLabel = `오늘 (${dateKey})`;
                    else if (dateKey === yesterday) dateLabel = `어제 (${dateKey})`;
                    else if (dateKey === dayBefore) dateLabel = `그제 (${dateKey})`;
                } else if (periodType === 'weekly') {
                    dateLabel = dateKey; // '이번 주', '지난 주'
                }

                cardsHTML += `
                    <div style="min-width:280px;flex-shrink:0;border:1px solid #ddd;border-radius:8px;padding:15px;background:#fafafa;">
                        <div style="font-weight:700;font-size:14px;color:#667eea;margin-bottom:15px;">${dateLabel}</div>
                        <div style="display:flex;flex-direction:column;gap:10px;">
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:13px;">📹 쇼츠</span>
                                <span style="font-weight:600;color:#f44336;">${shortsCount.toLocaleString()}개</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:13px;">🎬 비디오</span>
                                <span style="font-weight:600;color:#2196f3;">${videosCount.toLocaleString()}개</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:13px;">👤 채널</span>
                                <span style="font-weight:600;color:#4caf50;">${channelsCount.toLocaleString()}개</span>
                            </div>
                        </div>
                        <div style="margin-top:10px;padding-top:10px;border-top:1px solid #ddd;">
                            <div style="font-size:11px;color:#888;">총 ${(shortsCount + videosCount + channelsCount).toLocaleString()}개 수집</div>
                        </div>
                    </div>
                `;
            }

            container.innerHTML = cardsHTML;
        }

        // 새로고침 함수 (크롤러 대시보드에서 크롤링 후 호출)
        async function refreshCollectionStatus() {
            showToast('수집 현황 새로고침 중...', 'info');
            await loadCollectionStatus();
            await loadStats();
            await loadRecentCrawlHistory();
            showToast('수집 현황이 업데이트되었습니다.', 'success');
        }

        function populateFilters() {
            const catSelect = document.getElementById('crawlCategory');
            const countrySelect = document.getElementById('crawlCountry');

            // Clear existing options except first
            catSelect.innerHTML = '<option value="">전체 카테고리</option>';
            countrySelect.innerHTML = '<option value="">전체 국가</option>';

            categoriesList.forEach(cat => {
                const opt = document.createElement('option');
                opt.value = cat;
                opt.textContent = cat;
                catSelect.appendChild(opt);
            });

            countriesList.forEach(country => {
                const opt = document.createElement('option');
                opt.value = country;
                opt.textContent = country;
                countrySelect.appendChild(opt);
            });
        }

        // 크롤링 탭에서 쇼츠/비디오/채널 수집현황 한번에 표시
        function renderAllCollectionGrids() {
            // 쇼츠 요약 및 그리드
            const shortsTotal = collectionData.shorts.reduce((sum, i) => sum + (i.count || 0), 0);
