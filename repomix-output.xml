        // 수집 데이터 로드
        async function loadCollectedData() {
            const body = document.getElementById('collectedDataBody');
            body.innerHTML = '<div class="loading"><div class="spinner"></div></div>';

            try {
                const offset = (collectedDataPage - 1) * PAGE_SIZE;
                const params = new URLSearchParams({
                    type: collectedDataType,
                    limit: PAGE_SIZE,
                    offset: offset
                });
                const res = await fetch(`/api/crawl_data?${params}`);
                const data = await res.json();

                if (data.status === 'success') {
                    collectedDataTotalPages = Math.ceil(data.total / PAGE_SIZE) || 1;
                    updateCollectedDataPagination();

                    if (data.results.length > 0) {
                        renderCollectedDataTable(data.results, collectedDataType);
                        document.getElementById('collectedDataPagination').style.display = data.total > PAGE_SIZE ? 'flex' : 'none';
                    } else {
                        body.innerHTML = '<div class="empty-state"><div class="icon">📭</div><p>수집된 데이터가 없습니다</p></div>';
                        document.getElementById('collectedDataPagination').style.display = 'none';
                    }
                }
            } catch (e) {
                console.error('Collected data error:', e);
                body.innerHTML = '<div class="empty-state"><div class="icon">⚠️</div><p>데이터 로드 실패</p></div>';
            }
        }

