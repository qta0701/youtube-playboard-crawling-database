        // ========== Hybrid Playlist Export System ==========

        // 현재 표시된 크롤링 데이터에서 영상 ID 추출하여 내보내기
        async function exportToPlaylist() {
            const type = document.getElementById('crawlDataType').value;

            // 채널 타입일 경우 내보내기 불가
            if (type === 'channels') {
                showToast('채널은 재생목록에 추가할 수 없습니다. 영상/쇼츠를 선택해주세요.', 'error');
                return;
            }

            // 현재 필터 조건으로 모든 영상 ID 가져오기
            showToast('영상 목록을 불러오는 중...', 'info');

            try {
                const keyword = document.getElementById('crawlSearch').value;
                const category = document.getElementById('crawlCategory').value;
                const country = document.getElementById('crawlCountry').value;
                const period = document.getElementById('crawlPeriod').value;
                const crawlPeriodPreset = document.getElementById('crawlPeriodPreset').value;
                const uploadPeriodPreset = document.getElementById('uploadPeriodPreset').value;

                const params = new URLSearchParams({
                    type,
                    category,
                    country,
                    period,
                    keyword,
                    limit: 500,  // 최대 500개까지 내보내기 지원
                    offset: 0
                });

                // 기간 프리셋 적용
                if (crawlPeriodPreset && crawlPeriodPreset !== 'custom') {
                    params.append('crawl_period', crawlPeriodPreset);
                } else if (crawlPeriodPreset === 'custom') {
                    const from = document.getElementById('crawlDateFrom').value;
                    const to = document.getElementById('crawlDateTo').value;
                    if (from) params.append('crawl_date_from', from);
                    if (to) params.append('crawl_date_to', to);
                }

                if (uploadPeriodPreset && uploadPeriodPreset !== 'custom') {
                    params.append('upload_period', uploadPeriodPreset);
                } else if (uploadPeriodPreset === 'custom') {
                    const from = document.getElementById('uploadDateFrom').value;
                    const to = document.getElementById('uploadDateTo').value;
                    if (from) params.append('upload_date_from', from);
                    if (to) params.append('upload_date_to', to);
                }

                const res = await fetch(`/api/crawl_data?${params}`);
                const data = await res.json();

                if (data.status === 'success' && data.results.length > 0) {
                    // video_id 추출
                    const videoIds = data.results
                        .map(r => r.video_id)
                        .filter(id => id && id.length === 11);  // 유효한 video_id만

                    if (videoIds.length === 0) {
                        showToast('유효한 영상 ID가 없습니다.', 'error');
                        return;
                    }

                    // 중복 제거
                    const uniqueVideoIds = [...new Set(videoIds)];

                    openExportModal(uniqueVideoIds);
                } else {
                    showToast('내보낼 영상이 없습니다. 필터를 조정해보세요.', 'error');
                }
            } catch (e) {
                console.error('Export to playlist error:', e);
                showToast('영상 목록 조회 실패: ' + e.message, 'error');
            }
        }

        // 내보내기용 영상 ID 저장소
        let exportVideoIds = [];

        // 내보내기 모달 열기
        function openExportModal(videoIds) {
            if (!videoIds || videoIds.length === 0) {
                showToast('내보낼 영상을 선택해주세요.', 'error');
                return;
            }

            exportVideoIds = videoIds;
            document.getElementById('exportVideoCount').textContent = videoIds.length;
            document.getElementById('exportModal').classList.add('active');

            // 현재 필터 상태 표시
            updateExportFilterInfo();

            // 기본 재생목록 제목 설정
            const now = new Date();
            const defaultTitle = `대시보드 내보내기 ${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
            document.getElementById('exportPlaylistTitle').value = defaultTitle;

            // URL 방식 탭을 기본으로
            switchExportTab('url');

            // 인증 상태 확인
            checkExportAuthStatus();

            // URL 결과 초기화
            document.getElementById('exportUrlResults').innerHTML = '';
        }

        // 현재 필터 정보 표시
        function updateExportFilterInfo() {
            const type = document.getElementById('crawlDataType').value;
            const category = document.getElementById('crawlCategory').value;
            const country = document.getElementById('crawlCountry').value;
            const keyword = document.getElementById('crawlSearch').value;

            let filterInfo = [];
            if (type) filterInfo.push(`유형: ${type === 'shorts' ? '쇼츠' : type === 'videos' ? '비디오' : type}`);
            if (category && category !== 'all') filterInfo.push(`카테고리: ${category}`);
            if (country && country !== 'all') filterInfo.push(`국가: ${country}`);
            if (keyword) filterInfo.push(`검색어: "${keyword}"`);

            const infoText = filterInfo.length > 0 ? filterInfo.join(' | ') : '전체 데이터';
            const filterInfoEl = document.getElementById('exportFilterInfo');
            if (filterInfoEl) {
                filterInfoEl.textContent = infoText;
            }
        }

        // 내보내기 모달 닫기
        function closeExportModal() {
            document.getElementById('exportModal').classList.remove('active');
            exportVideoIds = [];
        }

        // 내보내기 탭 전환
        function switchExportTab(tabName) {
            document.querySelectorAll('.export-tab').forEach(tab => {
                tab.classList.toggle('active', tab.dataset.tab === tabName);
            });
            document.querySelectorAll('.export-tab-content').forEach(content => {
                content.classList.toggle('active', content.id === `exportTab${tabName.charAt(0).toUpperCase() + tabName.slice(1)}`);
            });

            // API 탭 선택 시 Quota 계산
            if (tabName === 'api') {
                updateExportQuotaEstimate();
            }
        }

        // 인증 상태 확인
        async function checkExportAuthStatus() {
            const statusEl = document.getElementById('exportAuthStatus');
            try {
                const res = await fetch('/api/export/auth/status');
                const data = await res.json();

                if (data.is_authenticated) {
                    statusEl.className = 'auth-status connected';
                    statusEl.innerHTML = `
                        <span class="status-icon">&#x2713;</span>
                        <span class="status-text">YouTube 계정이 연결되어 있습니다.</span>
                        <button class="btn btn-sm btn-secondary" onclick="exportAuthLogout()">연결 해제</button>
                    `;
                } else {
                    statusEl.className = 'auth-status';
                    statusEl.innerHTML = `
                        <span class="status-icon">&#x26A0;</span>
                        <span class="status-text">YouTube 계정 연결이 필요합니다.</span>
                        <button class="btn btn-sm btn-primary" onclick="exportAuthLogin()">계정 연결</button>
                    `;
                }
            } catch (e) {
                console.error('Auth status check error:', e);
                statusEl.className = 'auth-status';
                statusEl.innerHTML = `
                    <span class="status-icon">&#x274C;</span>
                    <span class="status-text">인증 상태 확인 실패</span>
                `;
            }
        }

        // OAuth 로그인
        async function exportAuthLogin() {
            const statusEl = document.getElementById('exportAuthStatus');
            statusEl.innerHTML = `
                <span class="status-icon">&#x23F3;</span>
                <span class="status-text">브라우저에서 Google 로그인을 진행해주세요...</span>
            `;

            try {
                const res = await fetch('/api/export/auth/login', { method: 'POST' });
                const data = await res.json();

                if (data.status === 'success') {
                    showToast('YouTube 계정 연결 완료!', 'success');
                    checkExportAuthStatus();
                } else {
                    showToast('로그인 실패: ' + data.message, 'error');
                    checkExportAuthStatus();
                }
            } catch (e) {
                showToast('로그인 오류: ' + e.message, 'error');
                checkExportAuthStatus();
            }
        }

        // OAuth 로그아웃
        async function exportAuthLogout() {
            if (!confirm('YouTube 계정 연결을 해제하시겠습니까?')) return;

            try {
                const res = await fetch('/api/export/auth/logout', { method: 'POST' });
                const data = await res.json();

                if (data.status === 'success') {
                    showToast('계정 연결이 해제되었습니다.', 'info');
                    checkExportAuthStatus();
                }
            } catch (e) {
                showToast('로그아웃 오류: ' + e.message, 'error');
            }
        }

        // Quota 예상치 업데이트
        async function updateExportQuotaEstimate() {
            const quotaInfoEl = document.getElementById('exportQuotaInfo');
            const videoCount = exportVideoIds.length;

            try {
                const res = await fetch('/api/export/quota_estimate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        video_count: videoCount,
                        new_playlist: true
                    })
                });
                const data = await res.json();

                let warningHtml = '';
                if (data.warning) {
                    warningHtml = `<div class="export-quota-warning">${data.warning}</div>`;
                }

                quotaInfoEl.innerHTML = `
                    <div class="export-quota-row">
                        <span>재생목록 생성</span>
                        <span>${data.breakdown.playlist_create} Quota</span>
                    </div>
                    <div class="export-quota-row">
                        <span>영상 추가 (${videoCount}개 x 50)</span>
                        <span>${data.breakdown.video_add.toLocaleString()} Quota</span>
                    </div>
                    <div class="export-quota-row total">
                        <span>예상 총 소모량</span>
                        <span>${data.estimated_quota.toLocaleString()} Quota</span>
                    </div>
                    <div class="export-quota-row" style="margin-top:10px;font-size:12px;color:#888;">
                        <span>현재 사용량 / 일일 한도</span>
                        <span>${data.current_usage.toLocaleString()} / ${data.daily_limit.toLocaleString()}</span>
                    </div>
                    ${warningHtml}
                `;
            } catch (e) {
                quotaInfoEl.innerHTML = '<div style="color:#f44336;">Quota 계산 오류</div>';
            }
        }

        // URL 방식 내보내기 실행
        async function executeExportUrl() {
            const btn = document.getElementById('btnExportUrl');
            const resultsEl = document.getElementById('exportUrlResults');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner" style="width:16px;height:16px;"></span> 생성 중...';

            try {
                const res = await fetch('/api/export/playlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        method: 'url',
                        video_ids: exportVideoIds
                    })
                });
                const data = await res.json();

                if (data.status === 'success') {
                    let html = '<div style="margin-bottom:10px;font-weight:600;color:#4caf50;">링크가 생성되었습니다!</div>';

                    data.urls.forEach((urlInfo, idx) => {
                        html += `
                            <div class="export-url-item">
                                <span style="font-weight:600;min-width:60px;">Part ${idx + 1}</span>
                                <a href="${urlInfo.url}" target="_blank" title="클릭하여 YouTube에서 열기">
                                    ${urlInfo.count}개 영상 (${urlInfo.start_index}-${urlInfo.end_index})
                                </a>
                                <button class="copy-btn" onclick="copyToClipboard('${urlInfo.url}')">복사</button>
                                <button class="copy-btn" style="background:#4caf50;" onclick="window.open('${urlInfo.url}', '_blank')">열기</button>
                            </div>
                        `;
                    });

                    html += `
                        <div class="export-info-box" style="margin-top:15px;">
                            <strong>다음 단계</strong>
                            위 링크를 클릭하면 YouTube에서 영상들이 재생됩니다.<br>
                            재생 화면에서 "저장" 버튼을 눌러 재생목록으로 저장하세요.
                        </div>
                    `;

                    resultsEl.innerHTML = html;
                    showToast(`${data.urls.length}개 링크 생성 완료!`, 'success');
                } else {
                    resultsEl.innerHTML = `<div style="color:#f44336;">오류: ${data.message}</div>`;
                }
            } catch (e) {
                resultsEl.innerHTML = `<div style="color:#f44336;">오류: ${e.message}</div>`;
            }

            btn.disabled = false;
            btn.innerHTML = '&#x1F517; 링크 생성';
        }

        // API 방식 내보내기 실행
        async function executeExportApi() {
            const btn = document.getElementById('btnExportApi');
            const playlistTitle = document.getElementById('exportPlaylistTitle').value.trim();
            const privacy = document.getElementById('exportPlaylistPrivacy').value;

            if (!playlistTitle) {
                showToast('재생목록 제목을 입력해주세요.', 'error');
                return;
            }

            if (!confirm(`${exportVideoIds.length}개 영상을 재생목록에 추가합니다.\n이 작업은 상당한 API Quota를 소모합니다.\n\n계속하시겠습니까?`)) {
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner" style="width:16px;height:16px;"></span> 처리 중...';

            try {
                const res = await fetch('/api/export/playlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        method: 'api',
                        video_ids: exportVideoIds,
                        playlist_title: playlistTitle,
                        privacy: privacy
                    })
                });
                const data = await res.json();

                if (data.status === 'success') {
                    let message = `재생목록 생성 완료!\n\n`;
                    message += `추가됨: ${data.added}개\n`;
                    if (data.skipped > 0) message += `건너뜀(중복): ${data.skipped}개\n`;
                    if (data.failed > 0) message += `실패: ${data.failed}개\n`;
                    message += `\nQuota 사용량: ${data.quota_used.toLocaleString()}`;

                    alert(message);
                    showToast('재생목록 생성 완료!', 'success');

                    // 재생목록 열기 확인
                    if (confirm('생성된 재생목록을 YouTube에서 열겠습니까?')) {
                        window.open(data.playlist_url, '_blank');
                    }

                    closeExportModal();
                    loadQuota(); // Quota 새로고침
                } else if (data.status === 'auth_required') {
                    showToast('YouTube 계정 연결이 필요합니다.', 'error');
                    checkExportAuthStatus();
                } else {
                    showToast('오류: ' + data.message, 'error');
                }
            } catch (e) {
                showToast('오류: ' + e.message, 'error');
            }

            btn.disabled = false;
            btn.innerHTML = '&#x1F680; 자동 저장 실행';
        }

        // 클립보드 복사
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                showToast('클립보드에 복사되었습니다.', 'success');
            }).catch(() => {
                showToast('복사 실패', 'error');
            });
        }

        // API 데이터 탭에서 선택된 영상 내보내기 버튼 추가를 위한 헬퍼
        function getSelectedApiVideoIds() {
            // API 데이터 탭에서 선택된 영상들의 ID를 수집하는 로직
            // 현재 API 데이터 탭은 썸네일 그리드 방식이므로
            // 별도의 체크박스 선택 기능이 필요함
            // 일단은 현재 표시된 모든 영상의 ID를 반환
            const videoCards = document.querySelectorAll('#apiThumbGrid .thumb-card:not(.channel)');
            const ids = [];
            videoCards.forEach(card => {
                const onclick = card.getAttribute('onclick');
                if (onclick) {
                    const match = onclick.match(/video_id=([^'&]+)/);
                    if (match) ids.push(match[1]);
                }
            });
            return ids;
        }

        // 모달 외부 클릭 시 닫기
        document.getElementById('exportModal')?.addEventListener('click', (e) => {
            if (e.target.classList.contains('export-modal')) {
                closeExportModal();
            }
        });
    </script>

    <!-- Playlist Export Modal -->
    <div id="exportModal" class="export-modal" onclick="if(event.target===this)closeExportModal()">
        <div class="export-modal-content">
            <div class="export-modal-header">
                <h3>&#x1F3AC; 재생목록으로 내보내기</h3>
                <button class="export-modal-close" onclick="closeExportModal()">&times;</button>
            </div>
            <div class="export-modal-body">
                <div style="margin-bottom:15px;">
                    <p style="margin:0 0 8px 0;">
                        선택된 영상: <strong id="exportVideoCount">0</strong>개
                    </p>
                    <p id="exportFilterInfo" style="margin:0;font-size:12px;color:#888;"></p>
                </div>

                <!-- Export Method Tabs -->
                <div class="export-tabs">
                    <button class="export-tab active" data-tab="url" onclick="switchExportTab('url')">
                        &#x1F517; 간편 링크 (비용 0)
                    </button>
                    <button class="export-tab" data-tab="api" onclick="switchExportTab('api')">
                        &#x1F680; 내 계정 연동 (자동)
                    </button>
                </div>

                <!-- Tab 1: URL Method -->
                <div id="exportTabUrl" class="export-tab-content active">
                    <div class="export-info-box">
                        <strong>간편 링크 방식</strong>
                        API Quota를 사용하지 않습니다. 링크를 클릭하면 YouTube에서 영상들이 재생되며,
                        그 상태에서 "저장" 버튼을 눌러 재생목록으로 저장할 수 있습니다.
                        <br><br>
                        &#x26A0; 한 번에 최대 50개 영상까지 지원됩니다. 초과 시 여러 링크로 분할됩니다.
                    </div>

                    <div class="export-btn-row">
                        <button id="btnExportUrl" class="export-btn export-btn-primary" onclick="executeExportUrl()">
                            &#x1F517; 링크 생성
                        </button>
                    </div>

                    <div id="exportUrlResults" class="export-url-results"></div>
                </div>

                <!-- Tab 2: API Method -->
                <div id="exportTabApi" class="export-tab-content">
                    <div class="export-info-box warning">
                        <strong>&#x26A0; API 자동화 방식</strong>
                        YouTube API를 통해 자동으로 재생목록을 생성하고 영상을 추가합니다.
                        <br><br>
                        <strong style="color:#f44336;">영상당 50 Quota가 소모됩니다!</strong>
                    </div>

                    <!-- Auth Status -->
                    <div id="exportAuthStatus" class="auth-status">
                        <span class="status-icon">&#x23F3;</span>
                        <span class="status-text">인증 상태 확인 중...</span>
                    </div>

                    <!-- Playlist Settings -->
                    <div class="export-form-group">
                        <label>재생목록 제목</label>
                        <input type="text" id="exportPlaylistTitle" placeholder="새 재생목록 이름을 입력하세요">
                    </div>

                    <div class="export-form-group">
                        <label>공개 설정</label>
                        <select id="exportPlaylistPrivacy">
                            <option value="private">비공개</option>
                            <option value="unlisted">일부 공개 (링크 공유)</option>
                            <option value="public">공개</option>
                        </select>
                    </div>

                    <!-- Quota Estimate -->
                    <div id="exportQuotaInfo" class="export-quota-info">
                        <div style="text-align:center;color:#888;">Quota 계산 중...</div>
                    </div>

                    <div class="export-btn-row">
                        <button id="btnExportApi" class="export-btn export-btn-primary" onclick="executeExportApi()">
                            &#x1F680; 자동 저장 실행
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
