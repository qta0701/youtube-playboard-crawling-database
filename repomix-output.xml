            const tbody = document.getElementById('resultsTableBody');
            tbody.innerHTML = '';

            data.forEach(item => {
                const row = document.createElement('tr');
                row.style.borderBottom = '1px solid #dee2e6';

                // 순위 변동 스타일
                const rankChange = item['Rank Change'] || '0';
                let rankChangeStyle = 'color: #6c757d;';
                if (String(rankChange).includes('NEW')) {
                    rankChangeStyle = 'color: #28a745; font-weight: bold;';
                } else if (String(rankChange).includes('+')) {
                    rankChangeStyle = 'color: #28a745;';
                } else if (String(rankChange).includes('-')) {
                    rankChangeStyle = 'color: #dc3545;';
                }

                // 프로필 이미지
                const profileImg = item['Profile Image'];
                const imgHtml = (profileImg && profileImg !== 'N/A')
                    ? `<img src="${profileImg}" alt="profile" style="width: 40px; height: 40px; border-radius: 50%;">`
                    : '-';

                // 태그 처리 (길면 자르기)
                let tags = item['Tags'] || '-';
                if (tags && tags.length > 20) {
                    tags = tags.substring(0, 20) + '...';
                }

                // 랭킹 타입 한글 표시
                const rankingTypeKo = item['Ranking Type'] || (rankingType === 'growth' ? '구독자 급상승' : '인기순위');

                // 랭킹 타입에 따라 다른 컬럼 표시 (CSV 컬럼 순서에 맞춤)
                if (rankingType === 'growth') {
                    // 구독자 급상승: Rank, Rank Change, Channel Name, Profile Image, Total Subscribers, New Subscribers, Growth Rate, Video Count, Tags, Country, Period, Ranking Date, Category, Ranking Type
                    row.innerHTML = `
                        <td style="padding: 8px; text-align: center;">${item['Rank'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;"><span style="${rankChangeStyle}">${rankChange}</span></td>
