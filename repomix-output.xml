        // 컬럼 헤더 클릭으로 정렬
        function sortByColumn(column) {
            const sortBySelect = document.getElementById('sortBy');
            const sortOrderSelect = document.getElementById('sortOrder');

            if (currentSortBy === column) {
                // 같은 컬럼 클릭 시 정렬 순서 토글
                currentSortOrder = currentSortOrder === 'asc' ? 'desc' : 'asc';
            } else {
                currentSortBy = column;
                currentSortOrder = 'desc';
            }

            sortBySelect.value = column;
            sortOrderSelect.value = currentSortOrder;
            updateSortIndicators();
            searchCrawlData();
        }

        // 정렬 표시 업데이트
        function updateSortIndicators() {
            document.querySelectorAll('th.sortable').forEach(th => {
                th.classList.remove('asc', 'desc');
                if (th.dataset.sort === currentSortBy) {
                    th.classList.add(currentSortOrder);
                }
            });
        }

        // 조회수 합산 뷰 토글
        function toggleAggregatedView() {
            isAggregatedView = document.getElementById('showAggregated').checked;
            // 카테고리별 순위와 중복 선택 방지
            if (isAggregatedView) {
                document.getElementById('showCategoryRank').checked = false;
                isCategoryRankView = false;
            }
            searchCrawlData();
        }

        // 카테고리별 전체 순위 뷰 토글
        function toggleCategoryRankView() {
            isCategoryRankView = document.getElementById('showCategoryRank').checked;
            // 조회수 합산과 중복 선택 방지
            if (isCategoryRankView) {
                document.getElementById('showAggregated').checked = false;
                isAggregatedView = false;
            }
            searchCrawlData();
        }

        // Load Crawl Data (개선된 버전)
        async function loadCrawlData() {
            await _fetchCrawlData();
        }

        // 검색 버튼 클릭 시 - 페이지 1로 초기화
        function searchCrawlData() {
            crawlPage = 1;
            _fetchCrawlData();
        }

        async function _fetchCrawlData() {
            const type = document.getElementById('crawlDataType').value;
            const keyword = document.getElementById('crawlSearch').value;
            const category = document.getElementById('crawlCategory').value;
            const country = document.getElementById('crawlCountry').value;
            const period = document.getElementById('crawlPeriod').value;
            const crawlPeriodPreset = document.getElementById('crawlPeriodPreset').value;
            const uploadPeriodPreset = document.getElementById('uploadPeriodPreset').value;
            const sortBy = document.getElementById('sortBy').value;
            const sortOrder = document.getElementById('sortOrder').value;
            const pageSize = parseInt(document.getElementById('pageSize').value);
            const offset = (crawlPage - 1) * pageSize;

            currentSortBy = sortBy;
            currentSortOrder = sortOrder;

            const tbody = document.getElementById('crawlResultsBody');
            tbody.innerHTML = '<tr><td colspan="11" class="loading"><div class="spinner"></div></td></tr>';

            try {
                const params = new URLSearchParams({
                    type,
                    category,
                    country,
                    period,
                    keyword,
                    sort_by: sortBy,
                    sort_order: sortOrder,
                    limit: pageSize,
                    offset
                });

                // 기간 프리셋 적용
                if (crawlPeriodPreset && crawlPeriodPreset !== 'custom') {
                    params.append('crawl_period', crawlPeriodPreset);
                } else if (crawlPeriodPreset === 'custom') {
                    const from = document.getElementById('crawlDateFrom').value;
                    const to = document.getElementById('crawlDateTo').value;
                    if (from) params.append('crawl_date_from', from);
                    if (to) params.append('crawl_date_to', to);
                }

                if (uploadPeriodPreset && uploadPeriodPreset !== 'custom' && type !== 'channels') {
                    params.append('upload_period', uploadPeriodPreset);
                } else if (uploadPeriodPreset === 'custom' && type !== 'channels') {
                    const from = document.getElementById('uploadDateFrom').value;
                    const to = document.getElementById('uploadDateTo').value;
                    if (from) params.append('upload_date_from', from);
                    if (to) params.append('upload_date_to', to);
                }

                // API URL 선택: 카테고리별 순위 > 조회수 합산 > 일반
                let apiUrl = '/api/crawl_data';
                if (isCategoryRankView) {
                    apiUrl = '/api/crawl_data/category_rank';
                } else if (isAggregatedView) {
                    apiUrl = '/api/crawl_data/aggregated';
                }

                const res = await fetch(`${apiUrl}?${params}`);
                const data = await res.json();

                if (data.status === 'success') {
                    crawlTotalPages = Math.ceil(data.total / pageSize) || 1;
                    updateCrawlPagination();
                    document.getElementById('crawlResultCount').textContent = `총 ${(data.total || data.count).toLocaleString()}개`;
                    document.getElementById('crawlPagination').style.display = (data.total || data.count) > pageSize ? 'flex' : 'none';

                    // Update table header based on type
                    updateCrawlTableHeader(type);
                    updateSortIndicators();

                    if (data.results.length > 0) {
                        if (isCategoryRankView) {
                            renderCategoryRankResults(data.results, type);
                        } else if (isAggregatedView) {
                            renderAggregatedResults(data.results);
                        } else if (type === 'channels') {
                            renderChannelResults(data.results);
                        } else {
                            renderVideoResults(data.results, type);
                        }
                    } else {
                        tbody.innerHTML = '<tr><td colspan="11" style="text-align:center;color:#888;">검색 결과가 없습니다</td></tr>';
                    }
                }
            } catch (e) {
                console.error('Crawl data error:', e);
                tbody.innerHTML = `<tr><td colspan="11" style="text-align:center;color:#f44336;">
                    <div style="padding:20px;">
                        <div style="font-size:18px;margin-bottom:10px;">❌ 데이터 로드 실패</div>
                        <div style="font-size:12px;color:#666;">${e.message}</div>
