### 6.2 SQLite 저장

```python
def save_to_db(videos, db_path='data/crawling_results.db'):
    """SQLite DB에 저장"""
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()

    # 테이블 생성
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS videos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            rank INTEGER,
            title TEXT,
            channel TEXT,
            channel_id TEXT,
            views INTEGER,
            likes INTEGER,
            comments INTEGER,
            thumbnail TEXT,
            crawled_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    # 데이터 삽입
    for video in videos:
        cursor.execute('''
            INSERT INTO videos (rank, title, channel, channel_id, views, likes, comments, thumbnail)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            video.get('Rank'),
            video.get('Title'),
            video.get('Channel'),
            video.get('Channel ID'),
            video.get('Views'),
            video.get('Likes'),
            video.get('Comments'),
            video.get('Thumbnail')
        ))

    conn.commit()
    conn.close()
