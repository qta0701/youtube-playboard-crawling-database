                    showToast('중복 삭제 실패: ' + removeData.message, 'error');
                    debugLog('ERROR', '중복 삭제 실패', removeData);
                }
            } catch (e) {
                console.error('Remove duplicates error:', e);
                showToast('중복 삭제 오류: ' + e.message, 'error');
                debugLog('ERROR', '중복 삭제 API 호출 실패', { error: e.message });
            }
        }

