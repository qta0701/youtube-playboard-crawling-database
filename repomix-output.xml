        async function exportData() {
            showToast('CSV 내보내기 준비 중...', 'info');

            const type = document.getElementById('crawlDataType').value;
            const keyword = document.getElementById('crawlSearch').value;
            const category = document.getElementById('crawlCategory').value;
            const country = document.getElementById('crawlCountry').value;

            const params = new URLSearchParams({
                type,
                category,
                country,
                keyword,
                limit: 10000,  // 최대 10000개
                offset: 0
            });

            try {
                const res = await fetch(`/api/crawl_data?${params}`);
                const data = await res.json();

                if (data.status === 'success' && data.results.length > 0) {
                    const results = data.results;
                    const headers = Object.keys(results[0]);
                    const csvContent = [
                        headers.join(','),
                        ...results.map(row => headers.map(h => {
                            let val = row[h] || '';
                            if (typeof val === 'string' && (val.includes(',') || val.includes('"'))) {
                                val = `"${val.replace(/"/g, '""')}"`;
                            }
                            return val;
                        }).join(','))
                    ].join('\n');

                    const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
                    const link = document.createElement('a');
                    link.href = URL.createObjectURL(blob);
                    link.download = `crawl_data_${type}_${new Date().toISOString().slice(0,10)}.csv`;
                    link.click();
                    showToast(`${results.length}개 데이터 내보내기 완료`, 'success');
                } else {
                    showToast('내보낼 데이터가 없습니다', 'error');
                }
            } catch (e) {
                console.error('Export error:', e);
                showToast('내보내기 실패', 'error');
            }
        }

        function updateCrawlPagination() {
            const pageSize = parseInt(document.getElementById('pageSize').value);
            document.getElementById('crawlPageInfo').textContent = `${crawlPage} / ${crawlTotalPages}`;
            document.getElementById('crawlPrev').disabled = crawlPage <= 1;
            document.getElementById('crawlNext').disabled = crawlPage >= crawlTotalPages;
        }

        function loadCrawlPage(direction) {
            crawlPage += direction;
            if (crawlPage < 1) crawlPage = 1;
            if (crawlPage > crawlTotalPages) crawlPage = crawlTotalPages;
            _fetchCrawlData();
        }

        // Channel Selection
        function toggleChannelSelection(checkbox) {
            const id = checkbox.dataset.id;
            if (checkbox.checked) {
                selectedChannels.add(id);
            } else {
                selectedChannels.delete(id);
            }
            updateSelectionUI();
        }

        function updateSelectionUI() {
            const count = selectedChannels.size;
            document.getElementById('selectedCount').textContent = count;
            document.getElementById('bulkSyncBtn').textContent = `선택 채널 API 동기화 (${count})`;
            document.getElementById('bulkSyncBtn').disabled = count === 0;

            const type = document.getElementById('crawlDataType').value;
            document.getElementById('actionBar').style.display = (type === 'channels' && count > 0) ? 'flex' : (type === 'channels' ? 'flex' : 'none');
        }

        function toggleSelectAll() {
            const checkAll = document.getElementById('selectAllChannels').checked;
            document.querySelectorAll('.channel-checkbox:not(:disabled)').forEach(cb => {
                cb.checked = checkAll;
                if (checkAll) {
                    selectedChannels.add(cb.dataset.id);
                } else {
                    selectedChannels.delete(cb.dataset.id);
                }
            });
            updateSelectionUI();
        }

        function selectAllVisible() {
            document.querySelectorAll('.channel-checkbox:not(:disabled)').forEach(cb => {
                cb.checked = true;
                selectedChannels.add(cb.dataset.id);
            });
            updateSelectionUI();
        }

        function clearSelection() {
            selectedChannels.clear();
            document.querySelectorAll('.channel-checkbox').forEach(cb => cb.checked = false);
            const selectAll = document.getElementById('selectAllChannels');
            if (selectAll) selectAll.checked = false;
            updateSelectionUI();
        }

        // Bulk Sync
        async function bulkSyncChannels() {
            const ids = Array.from(selectedChannels);
            if (ids.length === 0) return;

            const btn = document.getElementById('bulkSyncBtn');
            btn.disabled = true;
            btn.textContent = '동기화 중...';

            try {
                const res = await fetch('/api/sync/bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channel_ids: ids })
                });
                const data = await res.json();

                if (data.status === 'success') {
                    showToast(`${data.success_count}개 채널 동기화 완료` + (data.fail_count > 0 ? `, ${data.fail_count}개 실패` : '') + ` (${data.total_quota} 유닛 사용)`, 'success');
                    selectedChannels.clear();
                    updateSelectionUI();
                    loadCrawlData();
                    loadStats();
                    loadQuota();
                } else {
                    showToast('동기화 실패: ' + (data.message || '알 수 없는 오류'), 'error');
                }
            } catch (e) {
                showToast('동기화 오류', 'error');
            }

            btn.disabled = false;
            btn.textContent = `선택 채널 API 동기화 (${selectedChannels.size})`;
        }

        // Single Sync
        async function syncSingleChannel(channelId, btn) {
            btn.disabled = true;
            btn.textContent = '...';
            try {
                const res = await fetch('/api/sync/bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channel_ids: [channelId] })
                });
                const data = await res.json();
                if (data.status === 'success' && data.success_count > 0) {
                    showToast('채널 동기화 완료!', 'success');
                    loadCrawlData();
                    loadStats();
                    loadQuota();
                } else {
                    showToast('동기화 실패', 'error');
                    btn.disabled = false;
                    btn.textContent = '동기화';
                }
            } catch (e) {
                showToast('동기화 오류', 'error');
                btn.disabled = false;
                btn.textContent = '동기화';
            }
        }

        // 필터 상태 저장 (PLAN.md - 검색/필터 기능)
        let apiFilters = {};

        // Load API Data (Thumbnails) - PLAN.md Phase 2: 모든 서브탭에서 뷰 모드 지원
        async function loadApiData() {
            const grid = document.getElementById('apiThumbGrid');
            const tbody = document.getElementById('apiDataTableBody');

            debugLog('API_START', `API 데이터 로드 시작`, { subtype: currentApiSubtype, viewMode: apiViewMode, page: apiPage }, true);

            // 로딩 표시 (뷰 모드에 따라)
            if (apiViewMode === 'table') {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;"><div class="loading"><div class="spinner"></div></div></td></tr>';
            } else {
                grid.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
            }


            try {
                const offset = (apiPage - 1) * PAGE_SIZE;
                let url;
                if (currentApiSubtype === 'channels') {
                    url = `/api/channels/api?limit=${PAGE_SIZE}&offset=${offset}`;
                } else {
                    const type = currentApiSubtype === 'shorts' ? 'shorts' : 'video';
                    url = `/api/videos/list?type=${type}&limit=${PAGE_SIZE}&offset=${offset}`;

                    // 필터 파라미터 추가
                    if (apiFilters.channelId) url += `&channel_id=${apiFilters.channelId}`;  // PLAN.md 2.2: 채널 필터
                    if (apiFilters.search) url += `&search=${encodeURIComponent(apiFilters.search)}`;
                    if (apiFilters.viewMin) url += `&view_min=${apiFilters.viewMin}`;
                    if (apiFilters.viewMax) url += `&view_max=${apiFilters.viewMax}`;
                    if (apiFilters.likeRatioMin) url += `&like_ratio_min=${apiFilters.likeRatioMin}`;
                    if (apiFilters.likeRatioMax) url += `&like_ratio_max=${apiFilters.likeRatioMax}`;
                    if (apiFilters.dateFrom) url += `&date_from=${apiFilters.dateFrom}`;
                    if (apiFilters.dateTo) url += `&date_to=${apiFilters.dateTo}`;
                    if (apiFilters.category) url += `&category=${encodeURIComponent(apiFilters.category)}`;
                    if (apiFilters.sortBy) url += `&sort_by=${apiFilters.sortBy}`;
                }

                const res = await fetch(url);
                const data = await res.json();

                if (data.status === 'success') {
                    apiTotalPages = Math.ceil(data.total / PAGE_SIZE) || 1;
                    updateApiPagination();

                    if (currentApiSubtype === 'channels') {
                        // PLAN.md Phase 2: 채널도 테이블/그리드 뷰 모두 지원
                        if (apiViewMode === 'table') {
                            renderApiChannelsTable(data.channels);
                        } else {
                            renderApiChannels(data.channels);
                        }
                    } else {
                        // PLAN.md 2.1: 영상 데이터는 뷰 모드에 따라 렌더링
                        if (apiViewMode === 'table') {
                            renderApiVideosTable(data.videos);
                        } else {
                            renderApiVideos(data.videos);
                        }
                    }
                } else {
                    const emptyMsg = '<div class="empty-state"><div class="icon">📭</div><p>데이터가 없습니다</p></div>';
                    if (apiViewMode === 'table') {
                        tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;">${emptyMsg}</td></tr>`;
                    } else {
                        grid.innerHTML = emptyMsg;
                    }
                }
            } catch (e) {
                console.error('API data error:', e);
                const errorMsg = '<div class="empty-state"><div class="icon">⚠️</div><p>데이터 로드 실패</p></div>';
                if (apiViewMode === 'table') {
                    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;">${errorMsg}</td></tr>`;
                } else {
                    grid.innerHTML = errorMsg;
                }
            }
        }

        function renderApiChannels(channels) {
            const grid = document.getElementById('apiThumbGrid');
            if (!channels || channels.length === 0) {
                grid.innerHTML = '<div class="empty-state"><div class="icon">👤</div><p>API 채널이 없습니다. 크롤링 데이터 탭에서 채널을 동기화하세요.</p></div>';
                return;
            }
            // PLAN.md Phase 1: 채널 카드 UX 개선 - 더블클릭 제거, 명시적 버튼 추가
            grid.innerHTML = channels.map(ch => {
                const escapedTitle = (ch.title || '알 수 없음').replace(/'/g, "\\'");
                return `
                <div class="thumb-card channel" onclick="showChannelDetail('${ch.channel_id}')">
                    <img src="${ch.thumbnail_url || 'https://via.placeholder.com/100x100?text=N/A'}"
                         onerror="this.src='https://via.placeholder.com/100x100?text=N/A'">
                    <div class="info">
                        <div class="title">${ch.title || '알 수 없음'}</div>
                        <div class="meta">
                            <span class="badge channel">${ch.category || 'N/A'}</span>
                        </div>
                        <div class="channel-stats">
                            <span><span class="num">${formatNumber(ch.subscriber_count)}</span> 구독자</span>
                            <span><span class="num">${formatNumber(ch.video_count)}</span> 영상</span>
                            <span><span class="num">${formatNumber(ch.view_count)}</span> 조회수</span>
                        </div>
                        <div class="card-actions" style="margin-top:10px; display:flex; gap:5px;">
                            <button class="btn btn-sm" style="flex:1; background:#667eea; color:#fff; border:none; padding:6px; border-radius:4px; cursor:pointer; font-size:11px;"
                                    onclick="event.stopPropagation(); filterByChannel('${ch.channel_id}', '${escapedTitle}', 'shorts')">
                                <i class="fas fa-mobile-alt"></i> 쇼츠
                            </button>
                            <button class="btn btn-sm" style="flex:1; background:#3b82f6; color:#fff; border:none; padding:6px; border-radius:4px; cursor:pointer; font-size:11px;"
                                    onclick="event.stopPropagation(); filterByChannel('${ch.channel_id}', '${escapedTitle}', 'videos')">
                                <i class="fas fa-video"></i> 비디오
                            </button>
                        </div>
                    </div>
                </div>
            `}).join('');
            debugLog('SUCCESS', `채널 카드 렌더링 완료: ${channels.length}개 (버튼 UI 적용)`);
        }

        // PLAN.md Phase 2: 채널 테이블 뷰 렌더링 함수
        function renderApiChannelsTable(channels) {
            const tbody = document.getElementById('apiDataTableBody');
            const thead = document.querySelector('#apiDataTable thead tr');

            if (!channels || channels.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;"><div class="empty-state"><div class="icon">👤</div><p>API 채널이 없습니다.</p></div></td></tr>';
                return;
            }

            // 1. 헤더 변경 (채널 전용 컬럼)
            thead.innerHTML = `
                <th style="width:60px">#</th>
                <th style="width:300px">채널 정보</th>
                <th style="width:120px">구독자 수</th>
                <th style="width:100px">영상 수</th>
                <th style="width:120px">총 조회수</th>
                <th style="width:100px">동기화</th>
                <th style="width:80px">액션</th>
            `;

            // 2. DocumentFragment로 최적화된 렌더링
            const fragment = document.createDocumentFragment();

            channels.forEach((ch, index) => {
                const tr = document.createElement('tr');
                const profileImg = ch.thumbnail_url || 'https://via.placeholder.com/40x40?text=CH';
                const syncBadge = ch.is_synced
                    ? '<span class="badge" style="background:#4caf50;color:#fff;">Synced</span>'
                    : '<span class="badge" style="background:#ff9800;color:#fff;">Unsynced</span>';
                const escapedTitle = (ch.title || 'Unknown').replace(/'/g, "\\'").replace(/"/g, '&quot;');

                tr.innerHTML = `
                    <td style="text-align:center;">${(apiPage - 1) * PAGE_SIZE + index + 1}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <img src="${profileImg}" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" onerror="this.src='https://via.placeholder.com/40x40?text=CH'">
                            <div>
                                <a href="https://youtube.com/channel/${ch.channel_id}" target="_blank" style="font-weight:bold;color:#333;text-decoration:none;">
                                    ${ch.title || 'Unknown'}
                                </a>
                                <div style="font-size:11px;color:#888;">${ch.category || 'N/A'} • ${ch.country || 'N/A'}</div>
                            </div>
                        </div>
                    </td>
                    <td style="text-align:right;">${formatNumber(ch.subscriber_count)}</td>
                    <td style="text-align:right;">${ch.video_count || 0}개</td>
                    <td style="text-align:right;">${formatNumber(ch.view_count)}</td>
                    <td style="text-align:center;">${syncBadge}</td>
                    <td style="text-align:center;">
                        <button onclick="openChannelViewer('${ch.channel_id}', '${escapedTitle}')"
                                style="padding:4px 8px;background:#667eea;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:11px;"
                                title="이 채널의 영상 보기">
                            📺 보기
                        </button>
                    </td>
                `;
                fragment.appendChild(tr);
            });

            tbody.innerHTML = '';
            tbody.appendChild(fragment);
            debugLog('SUCCESS', `채널 테이블 렌더링 완료: ${channels.length}개`);
        }

        function renderApiVideos(videos) {
            const grid = document.getElementById('apiThumbGrid');
            if (!videos || videos.length === 0) {
                grid.innerHTML = `<div class="empty-state"><div class="icon">🎬</div><p>${currentApiSubtype === 'shorts' ? '쇼츠' : '비디오'}가 없습니다. 동기화된 채널에서 영상을 수집하세요.</p></div>`;
                return;
            }
            grid.innerHTML = videos.map(v => `
                <div class="thumb-card" onclick="window.open('https://youtube.com/watch?v=${v.video_id}', '_blank')">
                    <img src="https://img.youtube.com/vi/${v.video_id}/mqdefault.jpg"
                         onerror="this.src='https://via.placeholder.com/320x180?text=No+Thumb'">
                    <div class="info">
                        <div class="title">${v.title || '제목 없음'}</div>
                        <div class="meta">
                            <span class="views">${formatNumber(v.view_count)} 조회</span>
                            <span class="badge ${v.video_type}">${v.video_type === 'shorts' ? '쇼츠' : '비디오'}</span>
                        </div>
                        <div style="margin-top:8px;font-size:12px;color:#888;">
                            ${v.channel_name || '알 수 없음'} ${v.duration_sec ? '• ' + formatDuration(v.duration_sec) : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function updateApiPagination() {
            document.getElementById('apiPageInfo').textContent = `${apiPage} / ${apiTotalPages}`;
            document.getElementById('apiPrev').disabled = apiPage <= 1;
            document.getElementById('apiNext').disabled = apiPage >= apiTotalPages;
        }

        // PLAN.md 2.1: View Mode Toggle Functions (Phase 2 업데이트: 채널 테이블 뷰 지원)
        function setApiViewMode(mode) {
            apiViewMode = mode;
            debugLog('VIEW_MODE', `뷰 모드 변경: ${mode}, 서브타입: ${currentApiSubtype}`);

            // UI 업데이트: 버튼 active 상태
            const btnTable = document.getElementById('btnTableView');
            const btnGrid = document.getElementById('btnGridView');

            if (mode === 'table') {
                btnTable.style.borderColor = '#667eea';
                btnTable.style.background = '#667eea';
                btnTable.style.color = '#fff';
                btnGrid.style.borderColor = '#ddd';
                btnGrid.style.background = '#fff';
                btnGrid.style.color = '#333';

                // 컨테이너 표시/숨김
                document.getElementById('apiTableView').style.display = 'block';
                document.getElementById('apiGridView').style.display = 'none';
            } else {
                btnGrid.style.borderColor = '#667eea';
                btnGrid.style.background = '#667eea';
                btnGrid.style.color = '#fff';
                btnTable.style.borderColor = '#ddd';
                btnTable.style.background = '#fff';
                btnTable.style.color = '#333';

                // 컨테이너 표시/숨김
                document.getElementById('apiGridView').style.display = 'block';
                document.getElementById('apiTableView').style.display = 'none';
            }

            // 현재 데이터 다시 렌더링
            loadApiData();
        }

        // PLAN.md 2.1: Table View 렌더링 함수
        // PLAN.md 2.1.B: 테이블 뷰 렌더링 최적화 (DocumentFragment 사용)
        function renderApiVideosTable(videos) {
            // PLAN.md Phase 3: 프론트엔드 디버깅 - API 데이터 구조 확인
            if (videos && videos.length > 0) {
                console.group('📊 API Videos Table Render Debug');
                console.log('Video Type:', currentApiSubtype);
                console.log('Total Rows:', videos.length);
                console.table(videos[0]);
                console.groupEnd();
            }

            const tbody = document.getElementById('apiDataTableBody');
            if (!videos || videos.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:#888;">${currentApiSubtype === 'shorts' ? '쇼츠' : '비디오'}가 없습니다.</td></tr>`;
                return;
            }

            // PLAN.md 2.1.B: DocumentFragment를 사용하여 DOM 조작 최소화
            tbody.innerHTML = '';  // 기존 내용 클리어
            const fragment = document.createDocumentFragment();

            videos.forEach(v => {
                const publishedDate = v.published_at ? new Date(v.published_at).toLocaleDateString('ko-KR') : 'N/A';
                const likeCount = v.like_count ? formatNumber(v.like_count) : '-';
                const viewCount = v.view_count ? formatNumber(v.view_count) : '-';
                const typeLabel = v.video_type === 'shorts' ? '쇼츠' : '비디오';
                const typeBadgeClass = v.video_type === 'shorts' ? 'shorts' : 'video';

                const tr = document.createElement('tr');
                tr.style.cursor = 'pointer';
                tr.onclick = () => window.open(`https://youtube.com/watch?v=${v.video_id}`, '_blank');

                tr.innerHTML = `
                    <td style="text-align:center;">
                        <img src="https://img.youtube.com/vi/${v.video_id}/mqdefault.jpg"
                             style="width:60px;height:auto;border-radius:4px;"
                             onerror="this.src='https://via.placeholder.com/60x40?text=No+Thumb'">
                    </td>
                    <td><a href="https://youtube.com/watch?v=${v.video_id}" target="_blank" onclick="event.stopPropagation();" style="color:#667eea;text-decoration:none;">${v.title || '제목 없음'}</a></td>
                    <td>${v.channel_name || '알 수 없음'}</td>
                    <td style="text-align:right;">${viewCount}</td>
                    <td style="text-align:right;">${likeCount}</td>
                    <td>${publishedDate}</td>
                    <td><span class="badge ${typeBadgeClass}">${typeLabel}</span></td>
                `;

                fragment.appendChild(tr);
            });

            // 한 번에 DOM에 추가하여 Reflow 최소화
            tbody.appendChild(fragment);

            // PLAN.md Phase 1: Top Scroll 동기화 호출
            setTimeout(() => {
                syncTopScroll('apiDataTable');
            }, 100);
        }

        // 필터 적용 (PLAN.md - 검색/필터 기능)
        function applyAPIFilters() {
            apiFilters = {
                search: document.getElementById('apiSearchInput').value.trim(),
                viewMin: document.getElementById('apiViewMin').value,
                viewMax: document.getElementById('apiViewMax').value,
                likeRatioMin: document.getElementById('apiLikeRatioMin').value,
                likeRatioMax: document.getElementById('apiLikeRatioMax').value,
                dateFrom: document.getElementById('apiDateFrom').value,
                dateTo: document.getElementById('apiDateTo').value,
                category: document.getElementById('apiCategoryFilter').value,
                sortBy: document.getElementById('apiSortBy').value
            };

            apiPage = 1;  // 필터 적용 시 첫 페이지로
            loadApiData();
            debugLog('INFO', 'API 필터 적용됨', apiFilters);
        }

        // 필터 초기화 (PLAN.md - 검색/필터 기능)
        function resetAPIFilters() {
            document.getElementById('apiSearchInput').value = '';
            document.getElementById('apiViewMin').value = '';
            document.getElementById('apiViewMax').value = '';
            document.getElementById('apiLikeRatioMin').value = '';
            document.getElementById('apiLikeRatioMax').value = '';
            document.getElementById('apiDateFrom').value = '';
            document.getElementById('apiDateTo').value = '';
            document.getElementById('apiCategoryFilter').value = '';
            document.getElementById('apiSortBy').value = 'published_desc';

            apiFilters = {};
            apiPage = 1;
            loadApiData();
            debugLog('INFO', 'API 필터 초기화됨');
        }

        // PLAN.md 2.2: 채널별 필터링 함수
        // PLAN.md Phase 1: 채널 필터 함수 개선 - 타입 지원 (shorts/videos)
        function filterByChannel(channelId, channelName, type = 'shorts') {
            console.log(`[Channel Filter] 채널 필터 활성화: ${channelName} (${channelId}), 타입: ${type}`);

            // 채널 필터 정보 저장
            apiFilters.channelId = channelId;

            // 지정된 타입 탭으로 전환
            currentApiSubtype = type;
            document.querySelectorAll('.sub-tab').forEach(tab => {
                tab.classList.remove('active');
                if (tab.dataset.subtype === type) {
                    tab.classList.add('active');
                }
            });

            // 필터 섹션 표시
            document.getElementById('apiChannelFilterSection').style.display = 'block';
            document.getElementById('selectedChannelName').textContent = channelName;

            // 첫 페이지로 이동 후 데이터 로드
            apiPage = 1;
            loadApiData();

            debugLog('INFO', '채널 필터 적용', { channelId, channelName, type });
        }

