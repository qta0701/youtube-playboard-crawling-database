        // 채널 영상 로드
        async function loadChannelViewerVideos() {
            if (!cvChannelId) return;

            const grid = document.getElementById('cvVideoGrid');
            const tbody = document.getElementById('cvVideoTableBody');
            const typeFilter = document.getElementById('cvTypeFilter').value;
            const sortBy = document.getElementById('cvSortBy').value;
            const offset = (cvPage - 1) * CV_PAGE_SIZE;

            // 로딩 표시
            if (cvViewMode === 'grid') {
                grid.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
            } else {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;"><div class="loading"><div class="spinner"></div></div></td></tr>';
            }

            let url = `/api/videos/list?type=${typeFilter || 'all'}&channel_id=${cvChannelId}&limit=${CV_PAGE_SIZE}&offset=${offset}&sort_by=${sortBy}`;

            try {
                const res = await fetch(url);
                const data = await res.json();

                console.log(`[Channel Viewer] Loaded ${data.videos?.length || 0} videos (total: ${data.total})`);

                if (data.status === 'success') {
                    cvTotalPages = Math.ceil(data.total / CV_PAGE_SIZE) || 1;

                    if (cvViewMode === 'grid') {
                        renderCvGridView(data.videos);
                    } else {
                        renderCvTableView(data.videos);
                    }

                    updateCvPagination();
                } else {
                    if (cvViewMode === 'grid') {
                        grid.innerHTML = '<div class="empty-state"><div class="icon">🎬</div><p>영상을 불러올 수 없습니다.</p></div>';
                    } else {
                        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:#888;">영상을 불러올 수 없습니다.</td></tr>';
                    }
                }
            } catch (e) {
                console.error('[Channel Viewer] Videos load error:', e);
                if (cvViewMode === 'grid') {
                    grid.innerHTML = '<div class="empty-state"><div class="icon">⚠️</div><p>오류가 발생했습니다.</p></div>';
                }
            }
        }

        // 그리드 뷰 렌더링
        function renderCvGridView(videos) {
            const grid = document.getElementById('cvVideoGrid');

            if (!videos || videos.length === 0) {
                grid.innerHTML = '<div class="empty-state"><div class="icon">🎬</div><p>수집된 영상이 없습니다.</p></div>';
                return;
            }

            grid.innerHTML = videos.map(v => `
                <div class="thumb-card" onclick="window.open('https://youtube.com/watch?v=${v.video_id}', '_blank')">
                    <img src="https://img.youtube.com/vi/${v.video_id}/mqdefault.jpg"
                         onerror="this.src='https://via.placeholder.com/320x180?text=No+Thumb'">
                    <div class="info">
                        <div class="title">${v.title || '제목 없음'}</div>
                        <div class="meta">
                            <span class="views">${formatNumber(v.view_count)} 조회</span>
                            <span class="badge ${v.video_type}">${v.video_type === 'shorts' ? '쇼츠' : '비디오'}</span>
                        </div>
                        <div style="margin-top:8px;font-size:12px;color:#888;">
                            ${v.published_at ? new Date(v.published_at).toLocaleDateString('ko-KR') : ''} ${v.duration_sec ? '• ' + formatDuration(v.duration_sec) : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // 테이블 뷰 렌더링
        function renderCvTableView(videos) {
            const tbody = document.getElementById('cvVideoTableBody');

            if (!videos || videos.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:#888;">수집된 영상이 없습니다.</td></tr>';
                return;
            }

            tbody.innerHTML = '';
            const fragment = document.createDocumentFragment();

            videos.forEach(v => {
                const publishedDate = v.published_at ? new Date(v.published_at).toLocaleDateString('ko-KR') : 'N/A';
                const likeCount = v.like_count ? formatNumber(v.like_count) : '-';
                const viewCount = v.view_count ? formatNumber(v.view_count) : '-';
                const typeLabel = v.video_type === 'shorts' ? '쇼츠' : '비디오';
                const typeBadgeClass = v.video_type === 'shorts' ? 'shorts' : 'video';

                const tr = document.createElement('tr');
                tr.style.cursor = 'pointer';
                tr.onclick = () => window.open(`https://youtube.com/watch?v=${v.video_id}`, '_blank');

                tr.innerHTML = `
                    <td style="text-align:center;">
                        <img src="https://img.youtube.com/vi/${v.video_id}/mqdefault.jpg"
                             style="width:60px;height:auto;border-radius:4px;"
                             onerror="this.src='https://via.placeholder.com/60x40?text=No'">
                    </td>
                    <td><a href="https://youtube.com/watch?v=${v.video_id}" target="_blank" onclick="event.stopPropagation();" style="color:#667eea;text-decoration:none;">${v.title || '제목 없음'}</a></td>
                    <td style="text-align:right;">${viewCount}</td>
                    <td style="text-align:right;">${likeCount}</td>
                    <td>${publishedDate}</td>
                    <td><span class="badge ${typeBadgeClass}">${typeLabel}</span></td>
                `;

                fragment.appendChild(tr);
            });

            tbody.appendChild(fragment);
        }

