        // 채널 헤더 정보 로드
        async function loadChannelViewerHeader(channelId) {
            debugLog('API_START', `채널 헤더 로드 시작`, { channelId }, true);
            try {
                const res = await fetch(`/api/channel/${channelId}`);
                const data = await res.json();

                if (data.status === 'success') {
                    const ch = data.channel;
                    document.getElementById('cvChannelThumb').src = ch.thumbnail_url || 'https://via.placeholder.com/80?text=CH';
                    document.getElementById('cvChannelName').textContent = ch.title || 'Unknown';
                    document.getElementById('cvSubscriberCount').textContent = `구독자: ${formatNumber(ch.subscriber_count || 0)}`;
