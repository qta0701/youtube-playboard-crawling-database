                        <td style="padding: 8px; text-align: center;">${item['Category'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;"><span style="background: #28a745; color: white; padding: 2px 6px; border-radius: 10px; font-size: 0.8em;">${rankingTypeKo}</span></td>
                    `;
                } else {
                    // 인기순위: Rank, Rank Change, Channel Name, Profile Image, Views, Likes, Video Count, Tags, Country, Period, Ranking Date, Category, Ranking Type
                    row.innerHTML = `
                        <td style="padding: 8px; text-align: center;">${item['Rank'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;"><span style="${rankChangeStyle}">${rankChange}</span></td>
                        <td style="padding: 8px;">${item['Channel Name'] || 'N/A'}</td>
                        <td style="padding: 8px; text-align: center;">${imgHtml}</td>
                        <td style="padding: 8px; text-align: center;">${(item['Views'] || 0).toLocaleString()}</td>
                        <td style="padding: 8px; text-align: center;">${(item['Likes'] || 0).toLocaleString()}</td>
                        <td style="padding: 8px; text-align: center;">${item['Video Count'] || '-'}</td>
                        <td style="padding: 8px; font-size: 0.85em;">${tags}</td>
                        <td style="padding: 8px; text-align: center;">${item['Country'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item['Period'] || '-'}</td>
                        <td style="padding: 8px; text-align: center; font-size: 0.85em;">${item['Ranking Date'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item['Category'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;"><span style="background: #667eea; color: white; padding: 2px 6px; border-radius: 10px; font-size: 0.8em;">${rankingTypeKo}</span></td>
                    `;
                }

                tbody.appendChild(row);
            });
        }

        // 채널 랭킹 이벤트 리스너 등록
        document.querySelectorAll('input[name="channelRankType"]').forEach(el => {
            el.addEventListener('change', handleRankTypeChange);
        });
        document.querySelectorAll('input[name="channelPeriod"]').forEach(el => {
            el.addEventListener('change', updateChannelUrlPreview);
        });
        document.getElementById('channelCategory').addEventListener('change', updateChannelUrlPreview);
        document.getElementById('channelCountry').addEventListener('change', updateChannelUrlPreview);

        // ========== 수집 현황 대시보드 함수 ==========

        // 기간 설정 토글
        document.querySelectorAll('input[name="statusPeriod"]').forEach(el => {
            el.addEventListener('change', function() {
                const customRange = document.getElementById('customDateRange');
                if (this.value === 'custom') {
                    customRange.style.display = 'block';
                } else {
                    customRange.style.display = 'none';
                }
            });
        });

        // 수집 현황 로드
        async function loadCollectionStatus() {
            const periodType = document.querySelector('input[name="statusPeriod"]:checked').value;
            const startDate = document.getElementById('statusStartDate').value;
            const endDate = document.getElementById('statusEndDate').value;

            let url = `/api/collection_status?period_type=${periodType}`;
            if (periodType === 'custom' && startDate && endDate) {
                url += `&start_date=${startDate}&end_date=${endDate}`;
            }

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (data.status === 'success') {
                    renderCollectionStatus(data.collection_status);
                    renderCollectionSummary(data.summary);
                    updateDateRangeDisplay(periodType, startDate, endDate);
                    await loadCollectionHistory(periodType, startDate, endDate);
                } else {
                    showMessage('수집 현황 조회 실패: ' + data.message, 'error');
                }
            } catch (error) {
                showMessage('수집 현황 조회 오류: ' + error.message, 'error');
            }
        }

        // 기준 날짜 표시 업데이트
        function updateDateRangeDisplay(periodType, startDate, endDate) {
            const dateRangeDiv = document.getElementById('statusDateRange');
            const dateRangeText = document.getElementById('statusDateRangeText');
            const today = new Date();

            let text = '';
            if (periodType === 'daily') {
                text = `${today.toLocaleDateString('ko-KR')} (오늘)`;
            } else if (periodType === 'weekly') {
                const weekAgo = new Date(today);
                weekAgo.setDate(weekAgo.getDate() - 7);
                text = `${weekAgo.toLocaleDateString('ko-KR')} ~ ${today.toLocaleDateString('ko-KR')} (최근 7일)`;
            } else if (periodType === 'monthly') {
                const monthAgo = new Date(today);
                monthAgo.setDate(monthAgo.getDate() - 30);
                text = `${monthAgo.toLocaleDateString('ko-KR')} ~ ${today.toLocaleDateString('ko-KR')} (최근 30일)`;
            } else if (periodType === 'custom' && startDate && endDate) {
                text = `${startDate} ~ ${endDate}`;
            }

            dateRangeText.textContent = text;
            dateRangeDiv.style.display = 'block';
        }

        // 수집 이력 로드
        async function loadCollectionHistory(periodType, startDate, endDate) {
            let url = `/api/collection_history?period_type=${periodType}`;
            if (periodType === 'custom' && startDate && endDate) {
                url += `&start_date=${startDate}&end_date=${endDate}`;
            }

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (data.status === 'success') {
                    renderCollectionHistory(data.history);
                }
            } catch (error) {
                console.error('수집 이력 로드 오류:', error);
            }
        }

        // 요약 통계 렌더링
        function renderCollectionSummary(summary) {
            document.getElementById('summaryTotalCrawls').textContent = summary.total_crawls || 0;
            document.getElementById('summaryTotalItems').textContent = (summary.total_items || 0).toLocaleString();

            // 타입별 통계
            const byType = summary.by_type || {};
            const shortsCount = (byType.shorts?.items || 0) + (byType.video?.items || 0);
            const channelCount = (byType.channel_popular?.items || 0) + (byType.channel_growth?.items || 0);

            document.getElementById('summaryShorts').textContent = shortsCount.toLocaleString();
            document.getElementById('summaryChannels').textContent = channelCount.toLocaleString();
        }

        // 카테고리별 수집 현황 렌더링 (체크박스)
        function renderCollectionStatus(status) {
            // 쇼츠/영상 현황
            const shortsVideoContainer = document.getElementById('shortsVideoStatus');
            let shortsHtml = '<div style="margin-bottom: 8px; font-weight: bold; grid-column: span 2;">쇼츠</div>';

            for (const [category, collected] of Object.entries(status.shorts || {})) {
                const checkIcon = collected
                    ? '<span style="color: #28a745;">✓</span>'
                    : '<span style="color: #dc3545;">✗</span>';
                const bgColor = collected ? '#e8f5e9' : '#ffebee';
                shortsHtml += `
                    <div style="display: flex; align-items: center; gap: 6px; padding: 4px 8px; background: ${bgColor}; border-radius: 4px;">
                        ${checkIcon} ${category}
                    </div>
                `;
            }

            shortsHtml += '<div style="margin: 8px 0; font-weight: bold; grid-column: span 2; border-top: 1px solid #ddd; padding-top: 8px;">영상</div>';

            for (const [category, collected] of Object.entries(status.video || {})) {
                const checkIcon = collected
                    ? '<span style="color: #28a745;">✓</span>'
                    : '<span style="color: #dc3545;">✗</span>';
                const bgColor = collected ? '#e8f5e9' : '#ffebee';
                shortsHtml += `
                    <div style="display: flex; align-items: center; gap: 6px; padding: 4px 8px; background: ${bgColor}; border-radius: 4px;">
                        ${checkIcon} ${category}
                    </div>
                `;
            }

            shortsVideoContainer.innerHTML = shortsHtml;

            // 채널 현황
            const channelContainer = document.getElementById('channelStatus');
            let channelHtml = '<div style="margin-bottom: 8px; font-weight: bold; grid-column: span 2;">인기순위</div>';

            for (const [category, collected] of Object.entries(status.channel_popular || {})) {
                const checkIcon = collected
                    ? '<span style="color: #28a745;">✓</span>'
                    : '<span style="color: #dc3545;">✗</span>';
                const bgColor = collected ? '#e8f5e9' : '#ffebee';
                channelHtml += `
                    <div style="display: flex; align-items: center; gap: 6px; padding: 4px 8px; background: ${bgColor}; border-radius: 4px;">
                        ${checkIcon} ${category}
                    </div>
                `;
            }

            channelHtml += '<div style="margin: 8px 0; font-weight: bold; grid-column: span 2; border-top: 1px solid #ddd; padding-top: 8px;">구독자 급상승</div>';

            for (const [category, collected] of Object.entries(status.channel_growth || {})) {
                const checkIcon = collected
                    ? '<span style="color: #28a745;">✓</span>'
                    : '<span style="color: #dc3545;">✗</span>';
                const bgColor = collected ? '#e8f5e9' : '#ffebee';
                channelHtml += `
                    <div style="display: flex; align-items: center; gap: 6px; padding: 4px 8px; background: ${bgColor}; border-radius: 4px;">
                        ${checkIcon} ${category}
                    </div>
                `;
            }

            channelContainer.innerHTML = channelHtml;
        }

        // 상세 이력 테이블 렌더링
        function renderCollectionHistory(history) {
            const tbody = document.getElementById('collectionHistoryBody');

            if (!history || history.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" style="padding: 20px; text-align: center; color: #666;">
                            해당 기간에 수집 이력이 없습니다.
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';
            history.forEach(item => {
                const crawledAt = item.crawled_at ? new Date(item.crawled_at).toLocaleString('ko-KR') : '-';
                const typeLabel = getTypeLabel(item.target_type);
                const statusBadge = item.success
                    ? '<span style="background: #28a745; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">성공</span>'
                    : '<span style="background: #dc3545; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">실패</span>';

                html += `
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 8px;">${crawledAt}</td>
                        <td style="padding: 8px; text-align: center;">${typeLabel}</td>
                        <td style="padding: 8px;">${item.category || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item.country || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item.period || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item.item_count || 0}</td>
                        <td style="padding: 8px; text-align: center;">${statusBadge}</td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
        }

        // 타입 라벨 변환
        function getTypeLabel(targetType) {
            const labels = {
                'shorts': '<span style="background: #667eea; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">쇼츠</span>',
                'video': '<span style="background: #764ba2; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">영상</span>',
                'channel_popular': '<span style="background: #f5576c; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">채널(인기)</span>',
                'channel_growth': '<span style="background: #28a745; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">채널(급상승)</span>'
            };
            return labels[targetType] || `<span style="background: #6c757d; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8em;">${targetType}</span>`;
        }

        // ========== 데이터베이스 검색 함수 ==========
        async function searchDatabase() {
            const table = document.querySelector('input[name="dbTable"]:checked').value;
            const keyword = document.getElementById('dbSearchKeyword').value;
            const category = document.getElementById('dbSearchCategory').value;
            const country = document.getElementById('dbSearchCountry').value;
            const limit = document.getElementById('dbSearchLimit').value;

            const params = new URLSearchParams({
                table: table,
                keyword: keyword,
                category: category,
                country: country,
                limit: limit
            });

            try {
                const response = await fetch(`/api/db_search?${params}`);
                const data = await response.json();

                if (data.status === 'success') {
                    renderDbSearchResults(data.data, table);
                } else {
                    showMessage('검색 실패: ' + data.message, 'error');
                }
            } catch (error) {
                showMessage('검색 오류: ' + error.message, 'error');
            }
        }

        function renderDbSearchResults(data, table) {
            const resultsDiv = document.getElementById('dbSearchResults');
            const countSpan = document.getElementById('dbSearchCount');
            const tbody = document.getElementById('dbSearchTableBody');
            const thead = document.getElementById('dbSearchTableHead');

            countSpan.textContent = data.length;
            resultsDiv.style.display = 'block';

            // 테이블 헤더 변경 (채널 vs 쇼츠/영상)
            if (table === 'channels') {
                thead.innerHTML = `
                    <tr>
                        <th style="padding: 8px; text-align: center;">순위</th>
                        <th style="padding: 8px; text-align: left;">채널명</th>
                        <th style="padding: 8px; text-align: center;">스코어1</th>
                        <th style="padding: 8px; text-align: center;">스코어2</th>
                        <th style="padding: 8px; text-align: center;">카테고리</th>
                        <th style="padding: 8px; text-align: center;">수집일</th>
                    </tr>
                `;
            } else {
                thead.innerHTML = `
                    <tr>
                        <th style="padding: 8px; text-align: center;">순위</th>
                        <th style="padding: 8px; text-align: left;">제목</th>
                        <th style="padding: 8px; text-align: center;">조회수</th>
                        <th style="padding: 8px; text-align: left;">채널명</th>
                        <th style="padding: 8px; text-align: center;">카테고리</th>
                        <th style="padding: 8px; text-align: center;">수집일</th>
                    </tr>
                `;
            }

            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 20px; text-align: center; color: #666;">검색 결과가 없습니다.</td></tr>`;
                return;
            }

            let html = '';
            data.forEach(item => {
                const crawledAt = item.crawled_at ? new Date(item.crawled_at).toLocaleDateString('ko-KR') : '-';

                if (table === 'channels') {
                    html += `
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 8px; text-align: center;">${item.rank || '-'}</td>
                            <td style="padding: 8px;">${item.channel_name || '-'}</td>
                            <td style="padding: 8px; text-align: center;">${(item.score_1 || 0).toLocaleString()}</td>
                            <td style="padding: 8px; text-align: center;">${(item.score_2 || 0).toLocaleString()}</td>
                            <td style="padding: 8px; text-align: center;">${item.category || '-'}</td>
                            <td style="padding: 8px; text-align: center;">${crawledAt}</td>
                        </tr>
                    `;
                } else {
                    html += `
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 8px; text-align: center;">${item.rank || '-'}</td>
                            <td style="padding: 8px;">${item.title || '-'}</td>
                            <td style="padding: 8px; text-align: center;">${(item.views || 0).toLocaleString()}</td>
                            <td style="padding: 8px;">${item.channel_name || '-'}</td>
                            <td style="padding: 8px; text-align: center;">${item.category || '-'}</td>
                            <td style="padding: 8px; text-align: center;">${crawledAt}</td>
                        </tr>
                    `;
                }
            });

            tbody.innerHTML = html;
        }

        // ========== 크롤링 완료 팝업 알림 ==========
        function showCompletionPopup(message, itemCount) {
            // 알림음 재생 (2중 로직)
            playNotificationSound();

            // 팝업 요소 생성
            const popup = document.createElement('div');
            popup.id = 'completionPopup';
            popup.style.cssText = `
                position: fixed;
                bottom: 20px;
                right: 20px;
                background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
                color: white;
                padding: 20px 30px;
                border-radius: 12px;
                box-shadow: 0 10px 40px rgba(0,0,0,0.3);
                z-index: 10000;
                animation: slideIn 0.5s ease-out;
                max-width: 350px;
            `;
            popup.innerHTML = `
                <div style="font-size: 1.2em; font-weight: bold; margin-bottom: 8px;">✅ 크롤링 완료!</div>
                <div style="font-size: 0.95em;">${message}</div>
                <div style="font-size: 1.1em; margin-top: 10px; font-weight: bold;">${itemCount}개 항목 수집</div>
            `;

            // 스타일 추가 (애니메이션)
            if (!document.getElementById('popupStyles')) {
                const style = document.createElement('style');
                style.id = 'popupStyles';
                style.textContent = `
                    @keyframes slideIn {
                        from { transform: translateX(100%); opacity: 0; }
                        to { transform: translateX(0); opacity: 1; }
                    }
                    @keyframes slideOut {
                        from { transform: translateX(0); opacity: 1; }
                        to { transform: translateX(100%); opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
            }

            document.body.appendChild(popup);

            // 5초 후 사라짐
            setTimeout(() => {
                popup.style.animation = 'slideOut 0.5s ease-in';
                setTimeout(() => {
                    popup.remove();
                }, 500);
            }, 5000);
        }

        // 알림음 재생 (2중 로직 - 첫 번째 실패 시 두 번째 시도)
        function playNotificationSound() {
            // 1차 시도: Web Audio API
            try {
                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioContext.createOscillator();
                const gainNode = audioContext.createGain();

                oscillator.connect(gainNode);
                gainNode.connect(audioContext.destination);

                oscillator.frequency.value = 800;
                oscillator.type = 'sine';
                gainNode.gain.value = 0.3;

                oscillator.start();
                oscillator.stop(audioContext.currentTime + 0.3);

                // 두 번째 비프음
                setTimeout(() => {
                    const osc2 = audioContext.createOscillator();
                    const gain2 = audioContext.createGain();
                    osc2.connect(gain2);
                    gain2.connect(audioContext.destination);
                    osc2.frequency.value = 1000;
                    osc2.type = 'sine';
                    gain2.gain.value = 0.3;
                    osc2.start();
                    osc2.stop(audioContext.currentTime + 0.3);
                }, 200);

                console.log('Notification sound played (Web Audio API)');
                return;
            } catch (e) {
                console.warn('Web Audio API failed:', e);
            }

            // 2차 시도: 시스템 비프음 (ASCII bell)
            try {
                const bell = new Audio('data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQoGAACBhYqFbF1fdJivrJBhNjVgodDbq2EcBj+a2teleQAAdxM+pNPP');
                bell.volume = 0.5;
                bell.play().catch(() => {
                    // 최종 fallback: 콘솔 비프
                    console.log('\u0007');
                });
                console.log('Notification sound played (fallback audio)');
            } catch (e2) {
                console.warn('All sound methods failed');
            }
        }

        // 페이지 로드 시 채널 URL 미리보기 초기화 및 수집 현황 자동 로드
        window.addEventListener('load', () => {
            updateChannelUrlPreview();
            // 페이지 로드 시 오늘 수집 현황 자동 로드
            loadCollectionStatus();
        });
    </script>
</body>
</html>
