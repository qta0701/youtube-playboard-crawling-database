                    params.append(upload_date_to)

        # 전체 데이터일 때 videos_rank도 UNION
        if data_type == 'all':
            query += '''
                UNION ALL
                SELECT 'videos' as data_type, vr.id, vr.video_id, vr.title, vr.thumbnail_url,
                       vr.channel_name, vr.channel_id, vr.views, vr.likes, vr.rank, vr.rank_change,
