                        <th style="padding: 8px; text-align: center;">기간</th>
                        <th style="padding: 8px; text-align: center;">랭킹날짜</th>
                        <th style="padding: 8px; text-align: center;">카테고리</th>
                        <th style="padding: 8px; text-align: center;">랭킹타입</th>
                    </tr>
