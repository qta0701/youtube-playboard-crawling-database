                        <th style="padding: 8px; text-align: center;">증가폭</th>
                        <th style="padding: 8px; text-align: center;">영상수</th>
                        <th style="padding: 8px; text-align: center;">태그</th>
                        <th style="padding: 8px; text-align: center;">국가</th>
                        <th style="padding: 8px; text-align: center;">기간</th>
                        <th style="padding: 8px; text-align: center;">랭킹날짜</th>
                        <th style="padding: 8px; text-align: center;">카테고리</th>
                        <th style="padding: 8px; text-align: center;">랭킹타입</th>
                    </tr>
                `;
            } else {
                thead.innerHTML = `
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                        <th style="padding: 8px; text-align: center;">순위</th>
