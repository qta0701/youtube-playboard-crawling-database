        // Quota 예상치 계산 및 표시
        function updateQuotaEstimate() {
            const syncAll = document.getElementById('syncAllVideos').checked;
            const videoCountSelect = document.getElementById('syncVideoCount');
            const customInput = document.getElementById('syncVideoCountCustom');
            const estimateSpan = document.getElementById('quotaEstimate');

            let videoCount = 50;
            if (!syncAll) {
                if (videoCountSelect.value === 'custom') {
                    videoCount = parseInt(customInput.value) || 50;
                } else {
                    videoCount = parseInt(videoCountSelect.value);
                }
            }

            // Quota 계산: Channel info(1) + PlaylistItems(ceil(count/50)) + Videos(ceil(count/50))
            let quotaPerChannel;
            if (syncAll) {
                quotaPerChannel = '10~50+ (영상 개수에 따라 변동)';
            } else {
                const playlistQuota = Math.ceil(videoCount / 50);
                const videosQuota = Math.ceil(videoCount / 50);
                quotaPerChannel = 1 + playlistQuota + videosQuota;
            }

            estimateSpan.textContent = `채널당 약 ${quotaPerChannel} Quota 예상`;

            // 색상 변경
            if (syncAll || videoCount > 200) {
                estimateSpan.style.color = '#c62828'; // 빨강
                estimateSpan.style.fontWeight = '700';
            } else if (videoCount > 100) {
                estimateSpan.style.color = '#f57c00'; // 주황
            } else {
                estimateSpan.style.color = '#e65100'; // 기본
            }
        }

        // 동기화 옵션 값 가져오기
        function getSyncOptions() {
            const syncAll = document.getElementById('syncAllVideos').checked;
            const videoCountSelect = document.getElementById('syncVideoCount');
            const customInput = document.getElementById('syncVideoCountCustom');

            let videoLimit = 50;
            if (!syncAll) {
                if (videoCountSelect.value === 'custom') {
                    videoLimit = parseInt(customInput.value) || 50;
                } else {
                    videoLimit = parseInt(videoCountSelect.value);
                }
            }

            return {
                fetch_all: syncAll,
                video_limit: videoLimit
            };
        }

        // ==================== 기존 함수들 ====================

        // 오래된 채널 동기화 다이얼로그 표시
        function showOutdatedSyncDialog() {
            const days = prompt('마지막 동기화 후 며칠 이상 지난 채널을 동기화하시겠습니까?\n\n기본값: 7일\n입력 예: 7, 30, 60', '7');

            if (!days) return; // 취소

            const daysNum = parseInt(days);
            if (isNaN(daysNum) || daysNum < 1) {
                showToast('유효한 숫자를 입력해주세요. (1 이상)', 'error');
                return;
            }

            syncOutdatedChannels(daysNum);
        }

        // 오래된 채널 동기화 (N일 이상)
        async function syncOutdatedChannels(days = 7) {
            debugLog('CHANNEL_MANAGER', `오래된 채널 동기화 시작 (${days}일 이상)`);

            const confirmed = confirm(`마지막 동기화 후 ${days}일 이상 지난 채널들을 모두 동기화하시겠습니까?\n(시간이 오래 걸릴 수 있습니다)`);
            if (!confirmed) {
                debugLog('CHANNEL_MANAGER', '사용자가 오래된 채널 동기화 취소');
                return;
            }

            // 먼저 오래된 채널 목록 조회
            try {
                debugLog('API', `오래된 채널 조회 시작 (${days}일 기준)`);
                const res = await fetch(`/api/channel_manager/list?sync_status=synced&sort_by=days_since_sync&sort_order=desc&limit=1000`);
                const data = await res.json();

                if (data.status === 'success') {
                    const outdatedChannels = data.channels.filter(ch => ch.days_since_sync >= days);

                    debugLog('DETAIL', `오래된 채널 필터링 결과`, {
                        total: data.channels.length,
                        filtered: outdatedChannels.length,
                        criteria: `${days}일 이상`
                    });

                    if (outdatedChannels.length === 0) {
                        showToast(`${days}일 이상 지난 채널이 없습니다.`, 'info');
                        return;
                    }

                    const channelIds = outdatedChannels.map(ch => ch.channel_id);
                    showToast(`${channelIds.length}개 채널 동기화를 시작합니다...`, 'info', 3000);

                    // Batch 동기화 실행
                    debugLog('API', 'POST /api/channel_manager/sync/batch 호출', {
                        channel_count: channelIds.length,
                        fetch_videos: true
                    });

                    const syncRes = await fetch('/api/channel_manager/sync/batch', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            channel_ids: channelIds,
                            fetch_videos: true,
                            video_limit: 50
                        })
                    });

                    const syncData = await syncRes.json();

                    if (syncData.status === 'success') {
                        const success = syncData.results.success.length;
                        const failed = syncData.results.failed.length;
                        const quota = syncData.results.total_quota_used;

                        showToast(`오래된 채널 동기화 완료: 성공 ${success}개, 실패 ${failed}개 (Quota: ${quota})`, success > 0 ? 'success' : 'warning', 5000);

                        debugLog('SUCCESS', `오래된 채널 동기화 완료`, {
                            success,
                            failed,
                            quota,
                            days_criteria: days
                        });

                        loadChannelManagerStatus();
                        loadChannelManagerList();
                    } else {
                        showToast('동기화 실패: ' + (syncData.message || '서버 오류'), 'error');
                        debugLog('ERROR', '동기화 실패', { message: syncData.message });
                    }
                }
            } catch (e) {
                console.error('Outdated sync error:', e);
                showToast('오래된 채널 동기화 오류: ' + e.message, 'error');
                debugLog('ERROR', '오래된 채널 동기화 API 호출 실패', {
                    error: e.message,
                    stack: e.stack
                });
            }
        }

        // 체크된 채널만 동기화
        async function syncSelectedChannels() {
            if (cmSelectedChannels.size === 0) {
                showToast('동기화할 채널을 선택해주세요.', 'warning');
                return;
            }

            // 동기화 옵션 가져오기
            const syncOptions = getSyncOptions();
            const useDeepSearch = document.getElementById('useDeepSearch').checked;
            const videoDesc = syncOptions.fetch_all ? '전체 영상' : `최신 ${syncOptions.video_limit}개 영상`;

            // High-Cost 검색 활성화 시 2단계 확인
            if (useDeepSearch) {
                const highCostConfirm = confirm(
                    `⚠️ High-Cost 검색이 활성화되어 있습니다.\n\n` +
                    `• Low-Cost 복구 실패 시 YouTube 검색 API 사용\n` +
                    `• 실패한 채널당 +101 Quota 추가 소모\n` +
                    `• 비용이 매우 높으니 신중히 결정하세요.\n\n` +
                    `계속 진행하시겠습니까?`
                );
                if (!highCostConfirm) return;
            }

            // 일반 동기화 확인
            let confirmMsg = `${cmSelectedChannels.size}개 채널을 동기화하시겠습니까?\n\n`;
            confirmMsg += `📊 복구 방식:\n`;
            confirmMsg += `  • Low-Cost 복구: 항상 시도 (1 Quota)\n`;
            if (useDeepSearch) {
                confirmMsg += `  • High-Cost 검색: 실패 시 시도 (+101 Quota)\n`;
            } else {
                confirmMsg += `  • High-Cost 검색: 비활성화\n`;
            }
            confirmMsg += `\n🎬 영상 수집: ${videoDesc}`;

            const confirmed = confirm(confirmMsg);
            if (!confirmed) return;

            const btn = document.getElementById('btnSyncSelected');
            const originalText = btn.innerHTML;
            btn.disabled = true;

            debugLog('CHANNEL_MANAGER', '체크된 채널 동기화 시작', {
                channel_count: cmSelectedChannels.size,
                sync_options: syncOptions,
                use_deep_search: useDeepSearch
            });

            // Create progress bar element
            let progressBar = document.getElementById('batchSyncProgressBar');
            if (!progressBar) {
                progressBar = document.createElement('div');
                progressBar.id = 'batchSyncProgressBar';
                progressBar.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:white;padding:30px;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,0.3);z-index:10000;min-width:400px;';
                progressBar.innerHTML = `
                    <h3 style="margin:0 0 20px 0;text-align:center;">채널 동기화 진행 중...</h3>
                    <div style="background:#f0f0f0;border-radius:10px;height:30px;overflow:hidden;margin-bottom:15px;">
                        <div id="progressBarFill" style="background:linear-gradient(90deg, #4CAF50, #45a049);height:100%;width:0%;transition:width 0.3s;display:flex;align-items:center;justify-content:center;color:white;font-weight:bold;"></div>
                    </div>
                    <div id="progressText" style="text-align:center;font-size:14px;color:#666;margin-bottom:10px;"></div>
                    <div id="progressStats" style="text-align:center;font-size:12px;color:#999;"></div>
                `;
                document.body.appendChild(progressBar);
            }
            progressBar.style.display = 'block';

            // Start SSE connection for progress updates
            const eventSource = new EventSource('/api/channel_manager/sync/batch_progress');
            eventSource.onmessage = function(event) {
                const progress = JSON.parse(event.data);

                if (progress.status === 'completed') {
                    eventSource.close();
                    return;
                }

                const percentage = progress.percentage || 0;
                const progressBarFill = document.getElementById('progressBarFill');
                const progressText = document.getElementById('progressText');
                const progressStats = document.getElementById('progressStats');

                progressBarFill.style.width = percentage + '%';
                progressBarFill.textContent = percentage + '%';
                progressText.textContent = `[${progress.current}/${progress.total}] ${progress.current_channel}`;
                progressStats.textContent = `성공: ${progress.success_count} | 실패: ${progress.failed_count} | 복구: ${progress.recovered_count}`;
            };

            eventSource.onerror = function(e) {
                debugLog('ERROR', 'SSE 연결 오류', { error: e });
                eventSource.close();
            };

            try {
                const requestBody = {
                    channel_ids: Array.from(cmSelectedChannels),
                    fetch_videos: true,
                    video_limit: syncOptions.video_limit,
                    fetch_all: syncOptions.fetch_all,
                    use_search_fallback: useDeepSearch
                };

                debugLog('CHANNEL_MANAGER', 'batch_sync API 요청', {
                    url: '/api/channel_manager/sync/batch',
                    method: 'POST',
                    body: requestBody
                });

                const res = await fetch('/api/channel_manager/sync/batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestBody)
                });

                // HTTP 상태 체크
                if (!res.ok) {
                    debugLog('ERROR', 'batch_sync API HTTP 오류', { status: res.status, statusText: res.statusText });
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }

                let data;
                try {
                    data = await res.json();
                } catch (jsonError) {
                    debugLog('ERROR', 'batch_sync API JSON 파싱 실패', { error: jsonError.message });
                    throw new Error('서버 응답 파싱 실패');
                }

                debugLog('CHANNEL_MANAGER', 'batch_sync API 응답 수신', { status: data.status, httpStatus: res.status });

                // Close SSE connection
                eventSource.close();

                // Hide progress bar
                if (progressBar) {
                    progressBar.style.display = 'none';
                }

                debugLog('CHANNEL_MANAGER', '채널 동기화 완료', {
                    summary: data.summary,
                    success_channels: data.results?.success?.map(r => r.channel_name),
                    failed_channels: data.results?.failed?.map(r => ({ name: r.channel_name, error: r.error }))
                });

                if (data.status === 'success') {
                    const summary = data.summary || {};
                    const success = summary.success || data.results.success.length;
                    const failed = summary.failed || data.results.failed.length;
                    const recovered = summary.recovered || data.results.recovered?.length || 0;
                    const total = summary.total || cmSelectedChannels.size;
                    const quota = summary.quota_used || data.results.total_quota_used;

                    // 상세 정보 팝업
                    let message = `✅ 채널 동기화 완료\n\n`;
                    message += `총 ${total}개 중:\n`;
                    message += `  • 성공: ${success}개\n`;
                    if (recovered > 0) {
                        message += `  • 🔍 검색 복구: ${recovered}개\n`;
                    }
                    message += `  • 실패: ${failed}개\n`;
                    message += `  • 사용된 Quota: ${quota}\n`;

                    // Smart Recovery 성공 채널 표시 (복구 방식별 구분)
                    if (recovered > 0 && data.results.recovered && data.results.recovered.length > 0) {
                        const videoRecovered = data.results.recovered.filter(r => r.recovery_method === 'video');
                        const searchRecovered = data.results.recovered.filter(r => r.recovery_method === 'search');

                        if (videoRecovered.length > 0) {
                            message += `\n📊 Low-Cost 복구된 채널 (1 Quota/채널):\n`;
                            videoRecovered.forEach(r => {
                                message += `  - ${r.channel_name} (${r.old_id} → ${r.new_id})\n`;
                            });
                        }

                        if (searchRecovered.length > 0) {
                            message += `\n🔍 High-Cost 복구된 채널 (101 Quota/채널):\n`;
                            searchRecovered.forEach(r => {
                                message += `  - ${r.channel_name} (${r.old_id} → ${r.new_id})\n`;
                            });
                        }
                    }

                    if (failed > 0 && data.results.failed.length > 0) {
                        message += `\n실패한 채널:\n`;
                        data.results.failed.slice(0, 5).forEach(f => {
                            message += `  - ${f.channel_name || f.channel_id}: ${f.error}\n`;
                        });
                        if (data.results.failed.length > 5) {
                            message += `  ... 외 ${data.results.failed.length - 5}개\n`;
                        }
                    }

                    alert(message);

                    let toastMsg = `동기화 완료: 성공 ${success}개`;
                    if (recovered > 0) toastMsg += ` (복구 ${recovered}개)`;
                    toastMsg += `, 실패 ${failed}개 (Quota: ${quota})`;
                    showToast(toastMsg, success > 0 ? 'success' : 'warning', 3000);

                    // 선택 초기화
                    cmSelectedChannels.clear();
                    document.getElementById('cmSelectAll').checked = false;
                    updateSelectedCount();

                    // 목록 새로고침
                    loadChannelManagerStatus();
                    loadChannelManagerList();
                } else {
                    debugLog('ERROR', '채널 동기화 실패', { message: data.message });
                    showToast('동기화 실패: ' + (data.message || '서버 오류'), 'error');
                }
            } catch (e) {
                console.error('Sync selected channels error:', e);
                showToast('동기화 오류: ' + e.message, 'error');
                eventSource.close();
                if (progressBar) {
                    progressBar.style.display = 'none';
                }
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // 미동기화 채널 전체 동기화
        async function syncUnsyncedChannels() {
            try {
                // 먼저 미동기화 채널 개수 확인
                const res = await fetch('/api/channel_manager/list?sync_status=unsynced&limit=1000');
                const data = await res.json();

                if (data.status !== 'success') {
                    showToast('채널 목록 조회 실패', 'error');
                    return;
                }

                const unsyncedCount = data.total;
                if (unsyncedCount === 0) {
                    showToast('미동기화 채널이 없습니다.', 'info');
                    return;
                }

                const confirmed = confirm(`마지막 동기화 기록이 없는 ${unsyncedCount}개 채널을 모두 동기화하시겠습니까?\n(시간이 오래 걸릴 수 있습니다)`);
                if (!confirmed) return;

                const btn = document.getElementById('btnSyncUnsynced');
                const originalText = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 동기화 중...';

                try {
                    const syncRes = await fetch('/api/channel_manager/sync_unsynced', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    const syncData = await syncRes.json();

                    if (syncData.status === 'success') {
                        const success = syncData.results.success.length;
                        const failed = syncData.results.failed.length;
                        const quota = syncData.results.total_quota_used;

                        showToast(`미동기화 채널 동기화 완료: 성공 ${success}개, 실패 ${failed}개 (Quota: ${quota})`, success > 0 ? 'success' : 'warning', 3000);

                        // 목록 새로고침
                        loadChannelManagerStatus();
                        loadChannelManagerList();
                    } else {
                        showToast('동기화 실패: ' + (syncData.message || '서버 오류'), 'error');
                    }
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (e) {
                console.error('Sync unsynced channels error:', e);
                showToast('동기화 오류: ' + e.message, 'error');
            }
        }

