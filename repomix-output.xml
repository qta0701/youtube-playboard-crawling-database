        // 채널 관리 테이블 정렬 (클라이언트 사이드)
        let cmSortColumn = null;
        let cmSortOrder = 'asc';

        function sortCMTable(column) {
            // 정렬 순서 토글
            if (cmSortColumn === column) {
                cmSortOrder = cmSortOrder === 'asc' ? 'desc' : 'asc';
            } else {
                cmSortColumn = column;
                cmSortOrder = 'asc';
            }

            // 정렬 인디케이터 업데이트
            document.querySelectorAll('#cmTable th .sort-indicator').forEach(ind => ind.textContent = '');
            const header = document.querySelector(`#cmTable th[data-sort="${column}"]`);
            if (header) {
                const indicator = header.querySelector('.sort-indicator');
                if (indicator) indicator.textContent = cmSortOrder === 'asc' ? ' ▲' : ' ▼';
            }

            // 테이블 행 정렬
            const tbody = document.getElementById('cmTableBody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                let aVal, bVal;

                if (column === 'is_synced') {
                    aVal = a.querySelector('td:nth-child(2)').textContent.trim();
                    bVal = b.querySelector('td:nth-child(2)').textContent.trim();
                } else if (column === 'channel_name') {
                    aVal = a.getAttribute('data-channel-name') || '';
                    bVal = b.getAttribute('data-channel-name') || '';
                } else if (column === 'subscriber_count') {
                    aVal = parseInt(a.querySelector('td:nth-child(5)').textContent.replace(/[^0-9]/g, '') || '0');
                    bVal = parseInt(b.querySelector('td:nth-child(5)').textContent.replace(/[^0-9]/g, '') || '0');
                } else if (column === 'country') {
                    aVal = a.querySelector('td:nth-child(7)').textContent.trim();
                    bVal = b.querySelector('td:nth-child(7)').textContent.trim();
                } else if (column === 'last_synced_at') {
                    aVal = a.querySelector('td:nth-child(9)').textContent.trim();
                    bVal = b.querySelector('td:nth-child(9)').textContent.trim();
                } else if (column === 'collected_videos') {
                    aVal = parseInt(a.querySelector('td:nth-child(10)').textContent.trim() || '0');
                    bVal = parseInt(b.querySelector('td:nth-child(10)').textContent.trim() || '0');
                }

                if (aVal < bVal) return cmSortOrder === 'asc' ? -1 : 1;
                if (aVal > bVal) return cmSortOrder === 'asc' ? 1 : -1;
                return 0;
            });

            tbody.innerHTML = '';
            rows.forEach(row => tbody.appendChild(row));

            debugLog('INFO', `채널 테이블 정렬: ${column} ${cmSortOrder}`);
        }

        // 채널 관리 테이블 컬럼 리사이징
        function enableCMTableResizing() {
            const table = document.getElementById('cmTable');
            if (!table) return;

            table.style.tableLayout = 'fixed';

            const cols = table.querySelectorAll('thead th');
            let colgroup = table.querySelector('colgroup');
            if (!colgroup) {
                colgroup = document.createElement('colgroup');
                table.prepend(colgroup);
            }

            colgroup.innerHTML = '';
            cols.forEach(th => {
                const col = document.createElement('col');
                const width = th.style.width || th.getAttribute('width') || '100px';
                col.style.width = width;
                colgroup.appendChild(col);
            });

            // Resize handle 이벤트
            cols.forEach((th, index) => {
                const handle = th.querySelector('.resize-handle');
                if (!handle) return;

                let startX, startWidth;

                handle.addEventListener('mousedown', (e) => {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;

                    const onMouseMove = (e) => {
                        const diff = e.pageX - startX;
                        const newWidth = Math.max(30, startWidth + diff);
                        colgroup.children[index].style.width = newWidth + 'px';
                    };

                    const onMouseUp = () => {
                        document.removeEventListener('mousemove', onMouseMove);
                        document.removeEventListener('mouseup', onMouseUp);
                    };

                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                });
            });
        }

        // 구독자수 포맷 함수
        function formatSubscriberCount(count) {
            if (!count || count === 0) return '-';
            if (count >= 100000000) return (count / 100000000).toFixed(1) + '억';
            if (count >= 10000) return (count / 10000).toFixed(1) + '만';
            if (count >= 1000) return (count / 1000).toFixed(1) + 'K';
            return count.toLocaleString();
        }

        // 날짜 포맷 함수
        function formatDate(dateStr) {
            if (!dateStr) return '-';
            const d = new Date(dateStr);
            if (isNaN(d.getTime())) return dateStr;
            return d.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
        }

        // 채널 선택 토글
        function toggleChannelSelection(checkbox) {
            const channelId = checkbox.value;
            if (checkbox.checked) {
                cmSelectedChannels.add(channelId);
            } else {
                cmSelectedChannels.delete(channelId);
            }
            updateSelectedCount();
        }

        // 전체 선택/해제
        function toggleAllChannels(masterCheckbox) {
            const checkboxes = document.querySelectorAll('.cm-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = masterCheckbox.checked;
                if (masterCheckbox.checked) {
                    cmSelectedChannels.add(cb.value);
                } else {
                    cmSelectedChannels.delete(cb.value);
                }
            });
            updateSelectedCount();
        }

        // 선택된 채널 수 업데이트
        function updateSelectedCount() {
            const countEl = document.getElementById('cmSelectedCount');
            const count = cmSelectedChannels.size;
            countEl.textContent = count > 0 ? `${count}개 선택됨` : '';
        }

        // 페이지네이션 업데이트
        function updateCmPagination() {
            document.getElementById('cmPageInfo').textContent = `${cmPage} / ${cmTotalPages}`;
            document.getElementById('cmPrev').disabled = cmPage <= 1;
            document.getElementById('cmNext').disabled = cmPage >= cmTotalPages;
        }

        // 결과 정보 업데이트
        function updateCmResultInfo(count, total) {
            document.getElementById('cmResultInfo').textContent = `${count}개 표시 / 총 ${total}개`;
        }

        // 페이지 이동
        function loadChannelManagerPage(delta) {
            cmPage = Math.max(1, Math.min(cmTotalPages, cmPage + delta));
            loadChannelManagerList();
        }

        // 단일 채널 동기화
        async function syncSingleChannel(channelId, btn) {
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = '처리중...';

            try {
                const res = await fetch('/api/channel_manager/sync/batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        channel_ids: [channelId],
                        fetch_videos: true,
                        video_limit: 50
                    })
                });

                const data = await res.json();

                if (data.status === 'success') {
                    const success = data.results.success.length;
                    const failed = data.results.failed.length;

                    if (success > 0) {
                        showToast('채널 동기화 완료', 'success');
                        btn.textContent = '완료!';
                        setTimeout(() => {
                            loadChannelManagerStatus();
                            loadChannelManagerList();
                        }, 500);
                    } else {
                        showToast(`동기화 실패: ${data.results.failed[0]?.error || '알 수 없는 오류'}`, 'error');
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }
                } else {
                    showToast('동기화 실패: ' + (data.message || '서버 오류'), 'error');
                    btn.textContent = originalText;
                    btn.disabled = false;
                }
            } catch (e) {
                console.error('Sync error:', e);
                showToast('동기화 오류: ' + e.message, 'error');
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }

        // Batch 동기화 실행
        async function executeBatchSync(fetchVideos) {
            if (cmSelectedChannels.size === 0) {
                showToast('동기화할 채널을 선택해주세요.', 'warning');
                return;
            }

            const confirmed = confirm(`${cmSelectedChannels.size}개 채널을 동기화하시겠습니까?\n${fetchVideos ? '(영상 목록도 함께 수집됩니다)' : '(채널 정보만 수집됩니다)'}`);
            if (!confirmed) return;

            const btnId = fetchVideos ? 'btnBatchSyncAll' : 'btnBatchSyncChannel';
            const btn = document.getElementById(btnId);
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 동기화 중...';

            try {
                const res = await fetch('/api/channel_manager/sync/batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        channel_ids: Array.from(cmSelectedChannels),
                        fetch_videos: fetchVideos,
                        video_limit: 50
                    })
                });

                const data = await res.json();

                if (data.status === 'success') {
                    const success = data.results.success.length;
                    const failed = data.results.failed.length;
                    const quota = data.results.total_quota_used;

                    showToast(`동기화 완료: 성공 ${success}개, 실패 ${failed}개 (Quota: ${quota})`, success > 0 ? 'success' : 'warning');
                    debugLog('SUCCESS', `Batch 동기화 완료`, { success, failed, quota });

                    // 선택 초기화
                    cmSelectedChannels.clear();
                    document.getElementById('cmSelectAll').checked = false;
                    updateSelectedCount();

                    // PLAN.md Phase 3: 1초 딜레이 후 목록 새로고침 (DB Commit 대기)
                    setTimeout(async () => {
                        debugLog('ACTION', '동기화 완료 후 자동 새로고침 시작');
                        await loadChannelManagerStatus();
                        await loadChannelManagerList();
                        debugLog('SUCCESS', '동기화 후 목록 자동 갱신 완료');
                    }, 1000);
                } else {
                    showToast('Batch 동기화 실패: ' + (data.message || '서버 오류'), 'error');
                    debugLog('ERROR', 'Batch 동기화 실패', { message: data.message });
                }
            } catch (e) {
                debugLog('ERROR', 'Batch 동기화 오류', { error: e.message });
                showToast('Batch 동기화 오류: ' + e.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // ==================== 동기화 옵션 관련 함수 (PLAN.md) ====================

        // 전체 수집 토글
        function toggleSyncAllVideos(checkbox) {
            const videoCountSelect = document.getElementById('syncVideoCount');
            const customInput = document.getElementById('syncVideoCountCustom');

            if (checkbox.checked) {
                videoCountSelect.disabled = true;
                customInput.disabled = true;
                videoCountSelect.style.opacity = '0.5';
                customInput.style.opacity = '0.5';
            } else {
                videoCountSelect.disabled = false;
                customInput.disabled = false;
                videoCountSelect.style.opacity = '1';
                customInput.style.opacity = '1';
            }
        }

        // 사용자 지정 입력 토글
        document.addEventListener('DOMContentLoaded', function() {
            const select = document.getElementById('syncVideoCount');
            const customInput = document.getElementById('syncVideoCountCustom');

            select.addEventListener('change', function() {
                if (this.value === 'custom') {
                    customInput.style.display = 'inline-block';
                    customInput.value = 50;
                    customInput.focus();
                } else {
                    customInput.style.display = 'none';
