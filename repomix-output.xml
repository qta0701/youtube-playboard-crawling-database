                        tags.append(tag_text)
                tags_str = ','.join(tags) if tags else ''

                # 6. 조회수 (4번째 td)
                views = 0
                all_tds = row.select('td.score')
                if len(all_tds) >= 1:
                    views_text = all_tds[0].text.strip()
                    views = parse_korean_number_string(views_text)

                # 7. 좋아요 (5번째 td)
                likes = 0
