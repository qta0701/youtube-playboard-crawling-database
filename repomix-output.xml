                if crawl_period in period_days:
                    query += f" AND crawled_at >= datetime('now', '-{period_days[crawl_period]} days')"
            elif crawl_date_from:
                query += " AND DATE(crawled_at) >= ?"
                params.append(crawl_date_from)
            if crawl_date_to:
                query += " AND DATE(crawled_at) <= ?"
                params.append(crawl_date_to)
            if upload_period:
