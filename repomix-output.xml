        // 크롤링 데이터에서 채널 추출
        async function extractChannelsFromCrawl() {
            debugLog('CHANNEL_MANAGER', '========== 크롤링 데이터 채널 추출 시작 ==========');
            debugLog('CHANNEL_MANAGER', '버튼 클릭됨 - 사용자 확인 대기 중');

            if (!confirm('크롤링 데이터(shorts_rank, videos_rank, channels_rank)에서 채널을 추출하시겠습니까?\n\n• channel_id가 없는 채널도 추출됩니다 (동기화 시 ID 가져옴)\n• 기존에 없는 채널만 추가됩니다.')) {
                debugLog('CHANNEL_MANAGER', '사용자가 채널 추출 취소');
                return;
            }

            debugLog('CHANNEL_MANAGER', '사용자 확인 완료 - API 호출 시작');
            const startTime = performance.now();

            try {
                showToast('채널 추출 중... 잠시 기다려주세요.', 'info');
                debugLog('API', 'POST /api/channel_manager/extract_from_crawl 호출');

                const res = await fetch('/api/channel_manager/extract_from_crawl', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const elapsed = (performance.now() - startTime).toFixed(0);
                debugLog('API', `응답 수신 (${elapsed}ms)`, { status: res.status, ok: res.ok });

                const data = await res.json();
                debugLog('API', 'extract_from_crawl 응답 데이터', {
                    status: data.status,
                    extracted: data.extracted,
                    skipped: data.skipped,
                    message: data.message
                });

                // 소스별 상세 로그
                if (data.sources && data.sources.length > 0) {
                    debugLog('DETAIL', '=== 소스별 채널 추출 현황 ===');
                    data.sources.forEach(s => {
                        debugLog('DETAIL', `  ${s.source}:`, {
                            found: s.found,
                            extracted: s.extracted || 0
                        });
                    });
                }

                if (data.status === 'success') {
                    // 상세 메시지 생성
                    let sourceInfo = data.sources.map(s => {
                        return `${s.source}: ${s.extracted}개`;
                    }).join('\n');

                    const summaryMsg = `채널 추출 완료!\n\n` +
                        `✅ 추출: ${data.extracted}개\n` +
                        `⏭️ 스킵 (중복): ${data.skipped}개\n\n` +
                        `📊 소스별 현황:\n${sourceInfo}`;

                    showToast(summaryMsg, 'success', 8000);
                    debugLog('SUCCESS', '채널 추출 완료', {
                        extracted: data.extracted,
                        skipped: data.skipped,
                        elapsed: `${elapsed}ms`
                    });

                    // PLAN.md 2.2.B: 목록 새로고침 (DB 커밋 대기 후)
                    debugLog('CHANNEL_MANAGER', '채널 목록 새로고침 시작 (500ms 딜레이 적용)');
                    setTimeout(async () => {
                        await loadChannelManagerStatus();
                        await loadChannelManagerList();
                        debugLog('CHANNEL_MANAGER', '채널 목록 새로고침 완료');
                    }, 500);
                } else {
                    showToast('채널 추출 실패: ' + data.message, 'error');
                    debugLog('ERROR', '채널 추출 실패', { message: data.message, response: data });
                }
            } catch (e) {
                console.error('Extract channels error:', e);
                showToast('채널 추출 오류: ' + e.message, 'error');
                debugLog('ERROR', '채널 추출 API 호출 실패', {
                    error: e.message,
                    stack: e.stack
                });
            }

            debugLog('CHANNEL_MANAGER', '========== 크롤링 데이터 채널 추출 종료 ==========');
        }

        // 중복 채널 확인 및 삭제
        async function checkAndRemoveDuplicates() {
            debugLog('CHANNEL_MANAGER', '중복 채널 확인 시작');

            try {
                // 먼저 중복 확인
                const checkRes = await fetch('/api/channel_manager/check_duplicates');
                const checkData = await checkRes.json();
                debugLog('API', 'check_duplicates 응답', checkData);

                if (checkData.status !== 'success') {
                    showToast('중복 확인 실패: ' + checkData.message, 'error');
                    return;
                }

                if (checkData.total_duplicates === 0) {
                    showToast('중복 채널이 없습니다.', 'info');
                    debugLog('INFO', '중복 채널 없음');
                    return;
                }

                // 확인 팝업
                const confirmMsg = `중복 채널이 발견되었습니다!\n\n` +
                    `- 중복 그룹: ${checkData.duplicate_groups}개\n` +
                    `- 삭제 대상: ${checkData.total_duplicates}개\n\n` +
                    `최신 동기화 일자를 기준으로 하나만 남기고 삭제합니다.\n계속하시겠습니까?`;

                if (!confirm(confirmMsg)) {
                    debugLog('INFO', '사용자가 중복 삭제 취소');
                    return;
                }

                // 삭제 실행
                showToast('중복 채널 삭제 중...', 'info');
                const removeRes = await fetch('/api/channel_manager/remove_duplicates', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const removeData = await removeRes.json();
                debugLog('API', 'remove_duplicates 응답', removeData);

                if (removeData.status === 'success') {
                    showToast(`중복 채널 ${removeData.removed}개 삭제 완료!`, 'success');
                    debugLog('SUCCESS', `중복 채널 삭제 완료 - ${removeData.removed}개`);

                    // 목록 새로고침
                    await loadChannelManagerStatus();
                    await loadChannelManagerList();
