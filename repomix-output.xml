        // [PLAN Phase 2.1] JS 콘솔 로그 캡처 시스템
        let capturedLogs = [];

        /**
         * 로그를 캡처 배열에 저장하고 콘솔에도 출력하는 래퍼 함수.
         * @param {string} type - 'info', 'debug', 'warn', 'error'
         * @param {string} message - 로그 메시지
         * @param {any} optionalData - 추가 데이터 (객체 등)
         */
        function CaptureLog(type, message, optionalData) {
            const timestamp = new Date().toISOString();
            let logEntry = `[${timestamp}][${type.toUpperCase()}] ${message}`;

            // 콘솔 출력
            const consoleMethod = console[type] || console.log;
            if (optionalData !== undefined) {
                consoleMethod(logEntry, optionalData);
            } else {
                consoleMethod(logEntry);
            }

            // 캡처 배열에 저장
            if (optionalData !== undefined) {
                try {
                    logEntry += ' ' + JSON.stringify(optionalData);
                } catch (e) {
                    logEntry += ' [Circular or non-serializable data]';
                }
            }
            capturedLogs.push(logEntry);
        }

        // [NEW] 초기 컬럼 너비 저장소
        let initialColumnWidths = [];
        let initialCMColumnWidths = [];  // 채널 관리 테이블용

        // [PLAN Phase 1.1] 컬럼 리사이징 기능 (완벽 안정화)
        function enableColumnResizing() {
            const table = document.getElementById('crawlResultsTable');
            if (!table) {
                CaptureLog('warn', '[enableColumnResizing] crawlResultsTable not found');
                return;
            }

            // [FIX] table-layout을 fixed로 변경하여 다른 컬럼 너비 고정
            table.style.tableLayout = 'fixed';

            const cols = table.querySelectorAll('thead th');

            // [PLAN Phase 1.1] colgroup 생성 또는 가져오기
            let colgroup = table.querySelector('colgroup');
            if (!colgroup) {
                colgroup = document.createElement('colgroup');
                table.prepend(colgroup);
            }

            // [CRITICAL FIX] 초기 너비는 첫 번째 로드 시에만 저장
            // 이후 데이터 리로드 시에는 기존 초기 너비를 유지
            const isFirstLoad = initialColumnWidths.length === 0;
            if (isFirstLoad) {
                initialColumnWidths = [];
            }

            cols.forEach((col, index) => {
                // 기존 resizer가 있으면 제거 (중복 방지)
                const existingResizer = col.querySelector('.resizer');
                if (existingResizer) {
                    existingResizer.remove();
                }

                // [CRITICAL FIX #2] 첫 번째 로드 시에만 너비 설정
                // 이후 리로드 시에는 기존 style.width 값을 유지 (offsetWidth 읽지 않음)
                let currentWidth;
                if (isFirstLoad) {
                    // 첫 번째 로드: offsetWidth로 현재 렌더링된 너비 읽기
                    currentWidth = col.offsetWidth;
                    col.style.width = `${currentWidth}px`;
                    col.style.minWidth = '50px';
                    initialColumnWidths.push(currentWidth);
                } else {
                    // 이후 리로드: 기존 style.width 값 유지 (건드리지 않음)
                    // 이미 설정된 style.width가 있으면 그대로 사용
                    if (col.style.width && col.style.width.endsWith('px')) {
                        currentWidth = parseInt(col.style.width);
                    } else {
                        // 설정되지 않은 경우에만 offsetWidth 사용
                        currentWidth = col.offsetWidth;
                        col.style.width = `${currentWidth}px`;
                    }
                    col.style.minWidth = '50px';
                }

                // [PLAN Phase 1.1] colgroup의 col 요소 생성 및 width 설정
                let colElem = colgroup.children[index];
                if (!colElem) {
                    colElem = document.createElement('col');
                    colgroup.appendChild(colElem);
                }
                colElem.style.width = `${currentWidth}px`;
                colElem.style.minWidth = '50px';

                // 리사이저 핸들러 생성
                const resizer = document.createElement('div');
                resizer.classList.add('resizer');
                col.appendChild(resizer);

                let startX = 0;
                let startWidth = 0;
                let otherColsWidths = [];  // [NEW] 다른 컬럼들의 너비 저장

                const mouseDownHandler = (e) => {
                    startX = e.clientX;
                    startWidth = col.offsetWidth;

                    // [PLAN Phase 1.2] 모든 컬럼의 현재 너비를 픽셀 단위로 저장
                    otherColsWidths = [];
                    cols.forEach((c, i) => {
                        if (i !== index) {
                            otherColsWidths.push({ index: i, width: c.offsetWidth });
                        }
                        // [PLAN Phase 1.2] 모든 컬럼에 minWidth 설정
                        c.style.minWidth = '50px';
                    });

                    // [PLAN Phase 3.2] 상세 로그 추가
                    CaptureLog('debug', `[Resizer Start] Col ${index}. Start Width: ${startWidth}px. Total Fixed Cols: ${otherColsWidths.length}`);

                    resizer.classList.add('resizing');
                    document.body.style.cursor = 'col-resize';
                    document.body.style.userSelect = 'none';

                    document.addEventListener('mousemove', mouseMoveHandler);
                    document.addEventListener('mouseup', mouseUpHandler);

                    // 선택 방지
                    e.preventDefault();
                    e.stopPropagation();
                };

                const mouseMoveHandler = (e) => {
                    const dx = e.clientX - startX;
                    const newWidth = startWidth + dx;

                    const colgroup = table.querySelector('colgroup');
                    const tbody = table.querySelector('tbody');

                    // 최소 너비 50px
                    if (newWidth >= 50) {
                        // [PLAN Phase 1.3] 1. 해당 컬럼 너비 변경 (thead th)
                        col.style.width = `${newWidth}px`;

                        // [PLAN Phase 1.3] colgroup 업데이트
                        if (colgroup && colgroup.children[index]) {
                            colgroup.children[index].style.width = `${newWidth}px`;
                        }

                        // [PLAN Phase 1.3] tbody의 해당 컬럼 셀들 너비 변경
                        if (tbody) {
                            const rows = tbody.querySelectorAll('tr');
                            rows.forEach(row => {
                                const cell = row.children[index];
                                if (cell) {
                                    cell.style.width = `${newWidth}px`;
                                }
                            });
                        }

                        // [PLAN Phase 1.3] 2. 다른 모든 컬럼의 너비를 저장된 픽셀 값으로 강제 고정
                        otherColsWidths.forEach(({ index: otherIndex, width: otherWidth }) => {
                            const otherCol = cols[otherIndex];

                            // thead th 고정
                            otherCol.style.width = `${otherWidth}px`;

                            // colgroup 고정
                            if (colgroup && colgroup.children[otherIndex]) {
                                colgroup.children[otherIndex].style.width = `${otherWidth}px`;
                            }

                            // tbody 셀 고정
                            if (tbody) {
                                const rows = tbody.querySelectorAll('tr');
                                rows.forEach(row => {
                                    const cell = row.children[otherIndex];
                                    if (cell) {
                                        cell.style.width = `${otherWidth}px`;
                                    }
                                });
                            }
                        });

                        // [PLAN Phase 3.2] 상세 로그
                        CaptureLog('debug', `[Resizer Move] Col ${index}. New Width: ${newWidth}px. Delta: ${dx}px`);

                        // [CRITICAL FIX #2] updateTableScrollWidth() 호출 제거
                        // 드래그 중 호출하면 레이아웃 재계산으로 다른 컬럼 너비가 변경됨
                        // updateTableScrollWidth();
                    }
                };

                const mouseUpHandler = () => {
                    resizer.classList.remove('resizing');
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';

                    document.removeEventListener('mousemove', mouseMoveHandler);
                    document.removeEventListener('mouseup', mouseUpHandler);

                    // [PLAN Phase 1.1] 조정된 너비를 최종 너비로 반영 (너비 고정 유지)
                    // [FIX] updateTableScrollWidth()를 호출하기 BEFORE offsetWidth 읽기 전에 너비를 고정해야 함
                    const table = document.getElementById('crawlResultsTable');
                    const cols = table.querySelectorAll('thead th');
                    const colgroup = table.querySelector('colgroup');
                    const tbody = table.querySelector('tbody');

                    cols.forEach((col, idx) => {
                        // [CRITICAL FIX] col.style.width 값이 이미 설정되어 있으므로 이를 파싱하여 사용
                        // offsetWidth를 읽으면 브라우저의 재계산된 값을 가져오므로 부정확함
                        let finalWidth;
                        if (col.style.width && col.style.width.endsWith('px')) {
                            // 이미 설정된 픽셀 값 사용 (mouseMoveHandler에서 설정한 값)
                            finalWidth = parseInt(col.style.width);
                        } else {
                            // 혹시 설정되지 않은 경우 offsetWidth 사용
                            finalWidth = col.offsetWidth;
                        }

                        // th 최종 너비 설정
                        col.style.width = `${finalWidth}px`;

                        // colgroup 최종 너비 설정
                        if (colgroup && colgroup.children[idx]) {
                            colgroup.children[idx].style.width = `${finalWidth}px`;
                        }

                        // tbody 셀 최종 너비 설정
                        if (tbody) {
                            const rows = tbody.querySelectorAll('tr');
                            rows.forEach(row => {
                                const cell = row.children[idx];
                                if (cell) {
                                    cell.style.width = `${finalWidth}px`;
                                }
                            });
                        }
                    });

                    // Final Width를 로그에 기록
                    CaptureLog('debug', `[Resizer End] Col ${index}. Final Width: ${col.style.width}. Width retained.`);

                    // [CRITICAL FIX] updateTableScrollWidth()를 호출하지 않음
                    // 이 함수가 테이블 레이아웃 재계산을 유발하여 다른 컬럼 너비가 변경됨
                    // updateTableScrollWidth();
                };

                resizer.addEventListener('mousedown', mouseDownHandler);
            });

            // [CRITICAL FIX #2] 첫 번째 로드 시에만 테이블 전체 너비 업데이트
            // 이후 리로드 시에는 호출하지 않음 (레이아웃 재계산 방지)
            if (isFirstLoad) {
                updateTableScrollWidth();
            }

            // [PLAN Phase 2.1] 초기화 완료 로그 - 첫 번째 로드 여부 표시
            CaptureLog('info', `[Resizer Init] Column Resizing enabled for ${cols.length} columns. (First Load: ${isFirstLoad})`);
            if (isFirstLoad) {
                CaptureLog('debug', `[Resizer Init] Initial widths saved: ${initialColumnWidths.join('px, ')}px`);
            } else {
                CaptureLog('debug', `[Resizer Init] Initial widths preserved (not overwritten)`);
            }
        }

        // [PLAN Phase 2.1] 채널 관리 테이블 리사이징 기능
        function enableCMTableResizing() {
            const table = document.getElementById('cmTable');
            if (!table) {
                debugLog('WARN', '[enableCMTableResizing] cmTable not found');
                return;
            }

            // table-layout을 fixed로 변경하여 컬럼 너비 고정
            table.style.tableLayout = 'fixed';

