        // Helpers
        function formatNumber(num) {
            if (!num) return '0';
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num.toLocaleString();
        }

        function formatDuration(seconds) {
            if (!seconds) return '';
            const mins = Math.floor(seconds / 60);
            const secs = seconds % 60;
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        function showToast(message, type = 'info', duration = 3000) {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            // 줄바꿈을 지원하기 위해 innerHTML 사용 및 XSS 방지
            toast.style.whiteSpace = 'pre-line';
            toast.textContent = message;
            document.body.appendChild(toast);

            // 닫기 버튼 추가 (긴 메시지용)
            if (duration > 4000) {
                const closeBtn = document.createElement('span');
                closeBtn.textContent = ' ✕';
                closeBtn.style.cssText = 'cursor:pointer;margin-left:10px;opacity:0.7;';
                closeBtn.onclick = () => {
                    toast.style.animation = 'slideIn 0.3s reverse';
                    setTimeout(() => toast.remove(), 300);
                };
                toast.appendChild(closeBtn);
            }

            setTimeout(() => {
                toast.style.animation = 'slideIn 0.3s reverse';
                setTimeout(() => toast.remove(), 300);
            }, duration);
        }

        // 중복 데이터 제거 (PLAN.md Phase 2.2 - 로딩 상태 및 상세 결과 표시)
        async function removeDuplicates() {
            const btn = document.getElementById('btnRemoveDuplicates');
            const originalHTML = btn.innerHTML;

            try {
                // ========== Step 1: CHECK 모드 (미리보기) ==========
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 확인 중...';

                const checkRes = await fetch('/api/remove_duplicates', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mode: 'check', type: 'all' })
                });

                const checkData = await checkRes.json();

                if (!checkRes.ok || checkData.status !== 'success') {
                    throw new Error(checkData.message || '중복 데이터 확인 중 오류가 발생했습니다.');
                }

                const r = checkData.results;
                const total = r.shorts_rank + r.videos_rank + r.channels_rank;

                // 중복 데이터가 없는 경우
                if (total === 0) {
                    alert('중복된 데이터가 없습니다.');
                    return;
                }

                // 중복 데이터 미리보기 메시지
                const previewMsg = `[중복 데이터 분석 결과]\n\n` +
                                   `📱 쇼츠: ${r.shorts_rank}건\n` +
                                   `🎬 비디오: ${r.videos_rank}건\n` +
                                   `📺 채널: ${r.channels_rank}건\n\n` +
                                   `총 ${total}건의 중복 데이터가 발견되었습니다.\n\n` +
                                   `삭제하시겠습니까?\n(가장 최신 수집 데이터만 남기고 과거 중복 데이터는 삭제됩니다.)`;

                if (!confirm(previewMsg)) {
                    return;
                }

                // ========== Step 2: EXECUTE 모드 (실제 삭제) ==========
                btn.innerHTML = '<i class="fas fa-trash"></i> 삭제 중...';

                const execRes = await fetch('/api/remove_duplicates', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mode: 'execute', type: 'all' })
                });

                const execData = await execRes.json();

                if (!execRes.ok || execData.status !== 'success') {
                    throw new Error(execData.message || '중복 데이터 삭제 중 오류가 발생했습니다.');
                }

                // 삭제 완료 메시지
                const er = execData.results;
                const resultMsg = `중복 데이터 제거가 완료되었습니다!\n\n` +
                                  `📱 쇼츠: ${er.shorts_rank}개 삭제\n` +
                                  `🎬 비디오: ${er.videos_rank}개 삭제\n` +
                                  `📺 채널: ${er.channels_rank}개 삭제\n\n` +
                                  `총 ${execData.total}개 정리됨`;

                alert(resultMsg);

                // 데이터 새로고침
                searchCrawlData();
                loadStats();
                refreshCollectionStatus();

            } catch (error) {
                console.error('Duplicate removal error:', error);
                alert('오류가 발생했습니다: ' + error.message);
            } finally {
                // 버튼 상태 복구
                btn.disabled = false;
                btn.innerHTML = originalHTML;
            }
        }

        // 카테고리 필터 버튼 클릭 핸들러 (Phase 3.2)
        function setCategoryFilter(category) {
            // 숨겨진 select 요소 값 변경
            document.getElementById('crawlCategory').value = category;

            // 버튼 active 상태 업데이트
