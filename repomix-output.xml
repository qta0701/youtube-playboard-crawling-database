        // 수집 현황 카테고리 항목 클릭 시 필터링
        function filterByCategoryItem(type, category, country) {
            // 수집 데이터 섹션으로 스크롤
            document.getElementById('crawlDataCard').scrollIntoView({ behavior: 'smooth', block: 'start' });

            // 필터 설정
            document.getElementById('crawlDataType').value = type;
            document.getElementById('crawlCategory').value = category || '';
            document.getElementById('crawlCountry').value = country || '';

            // 데이터 타입 변경 이벤트 트리거 (업로드 필터 표시/숨김)
            onDataTypeChange();

            // 검색 실행
            setTimeout(() => searchCrawlData(), 300);

            // 토스트 알림
            showToast(`${category || '전체'} 카테고리 데이터로 필터링되었습니다`, 'info');
        }

        // 수집 현황 날짜 필터 관련 변수
        let collectionDatesList = [];
        let collectionSelectedDate = '';
        let collectionPeriodType = 'daily';  // daily or weekly

        // 수집 현황 기간 타입 변경 (일간/주간)
        function onCollectionPeriodTypeChange() {
            const periodType = document.getElementById('collectionPeriodType').value;
            collectionPeriodType = periodType;

            const dailySelect = document.getElementById('collectionDailyDate');
            const weeklySelect = document.getElementById('collectionWeeklyDate');

            if (periodType === 'daily') {
                dailySelect.style.display = 'inline-block';
                weeklySelect.style.display = 'none';
                populateCollectionDates();
            } else {
                dailySelect.style.display = 'none';
                weeklySelect.style.display = 'inline-block';
                populateCollectionWeeks();
            }
        }

        // 최근 7일 날짜 목록 생성
        function populateCollectionDates() {
            const select = document.getElementById('collectionDailyDate');
            select.innerHTML = '<option value="">전체 날짜</option>';

            const today = new Date();
            for (let i = 0; i < 7; i++) {
                const date = new Date(today);
                date.setDate(today.getDate() - i);
                const dateStr = date.toISOString().split('T')[0];
                const displayStr = date.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric', weekday: 'short' });

                const option = document.createElement('option');
                option.value = dateStr;
                option.textContent = i === 0 ? `오늘 (${displayStr})` : displayStr;
                select.appendChild(option);
            }
        }

        // 최근 4주 날짜 범위 생성
        function populateCollectionWeeks() {
            const select = document.getElementById('collectionWeeklyDate');
            select.innerHTML = '<option value="">전체 주간</option>';

            const today = new Date();
            const currentDay = today.getDay();
            const diff = currentDay === 0 ? 6 : currentDay - 1;  // 월요일 기준

            for (let i = 0; i < 4; i++) {
                const weekStart = new Date(today);
                weekStart.setDate(today.getDate() - diff - (i * 7));
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekStart.getDate() + 6);

                const startStr = weekStart.toISOString().split('T')[0];
                const endStr = weekEnd.toISOString().split('T')[0];
                const displayStr = `${weekStart.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })} ~ ${weekEnd.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}`;

                const option = document.createElement('option');
                option.value = `${startStr}|${endStr}`;
                option.textContent = i === 0 ? `이번 주 (${displayStr})` : displayStr;
                select.appendChild(option);
            }
        }

        // 수집 현황 날짜 필터 적용
        function filterCollectionByDate() {
            const periodType = document.getElementById('collectionPeriodType').value;

            if (periodType === 'daily') {
                const dateValue = document.getElementById('collectionDailyDate').value;
                collectionSelectedDate = dateValue;
                updateCollectionFilterInfo(dateValue);
            } else {
                const weekValue = document.getElementById('collectionWeeklyDate').value;
                collectionSelectedDate = weekValue;
                updateCollectionFilterInfo(weekValue, true);
            }

            // 수집 현황 다시 로드 (필터 적용)
            loadCollectionStatus();
        }

        // 필터 정보 표시 업데이트
        function updateCollectionFilterInfo(value, isWeekly = false) {
            const infoDiv = document.getElementById('collectionFilterInfo');

            if (!value) {
                infoDiv.textContent = '전체 기간';
            } else if (isWeekly) {
                const [start, end] = value.split('|');
                infoDiv.textContent = `${new Date(start).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })} ~ ${new Date(end).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}`;
            } else {
                const date = new Date(value);
                infoDiv.textContent = date.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric', weekday: 'short' });
            }
        }

        // 페이지 로드 시 날짜 목록 초기화
        document.addEventListener('DOMContentLoaded', () => {
            populateCollectionDates();
        });

        // 수집 데이터 섹션 토글
        function toggleCollectionData(type) {
            const section = document.getElementById('collectedDataSection');
            const headers = ['shortsHeader', 'videosHeader', 'channelsHeader'];

            // 모든 헤더 expanded 클래스 제거
            headers.forEach(h => document.getElementById(h).classList.remove('expanded'));

            // 같은 타입을 다시 클릭하면 닫기
            if (collectedDataType === type && section.classList.contains('active')) {
                section.classList.remove('active');
                collectedDataType = null;
                return;
            }

            // 새 타입 선택
            collectedDataType = type;
            collectedDataPage = 1;
            document.getElementById(type + 'Header').classList.add('expanded');

            const typeNames = { shorts: '쇼츠', videos: '비디오', channels: '채널' };
            document.getElementById('collectedDataTitle').textContent = `${typeNames[type]} 수집 데이터`;

            section.classList.add('active');
            loadCollectedData();

            // 섹션으로 스크롤
            setTimeout(() => section.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
