latest_crawl_data = []  # 최근 크롤링 결과 저장


def add_log(message):
    timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    log_entry = f"[{timestamp}] {message}"
    status_logs.append(log_entry)
    logger.info(message)
    if len(status_logs) > 100:
        status_logs.pop(0)


