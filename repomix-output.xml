                        <td style="padding: 8px; text-align: center;">${(item['Total Subscribers'] || 0).toLocaleString()}</td>
                        <td style="padding: 8px; text-align: center;">${(item['New Subscribers'] || 0).toLocaleString()}</td>
                        <td style="padding: 8px; text-align: center; color: #28a745; font-weight: bold;">${item['Growth Rate'] || '-'}</td>
                        <td style="padding: 8px; text-align: center;">${item['Video Count'] || '-'}</td>
                        <td style="padding: 8px; font-size: 0.85em;">${tags}</td>
